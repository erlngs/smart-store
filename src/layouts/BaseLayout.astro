---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  bodyClass?: string;
  description?: string;
}

const { title, bodyClass = "", description = "SmartStore - Belanja online produk berkualitas dengan harga terbaik." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link href="/assets/store/img/favicon.png" rel="icon" />
    <link href="/assets/store/img/apple-touch-icon.png" rel="apple-touch-icon" />

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@100;300;400;500;700;900&family=Montserrat:wght@100;200;300;400;500;600;700;800;900&family=Poppins:wght@100;200;300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />

    <link href="/assets/store/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <link href="/assets/store/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />
    <link href="/assets/store/vendor/swiper/swiper-bundle.min.css" rel="stylesheet" />
    <link href="/assets/store/vendor/aos/aos.css" rel="stylesheet" />
    <link href="/assets/store/vendor/drift-zoom/drift-basic.css" rel="stylesheet" />
    <link href="/assets/store/vendor/glightbox/css/glightbox.min.css" rel="stylesheet" />
    <link href="/assets/store/css/main.css" rel="stylesheet" />

    <!-- ===== GLOBAL CURSOR POINTER ===== -->
    <style>
      a,
      button,
      [role="button"],
      .btn,
      .nav-link,
      .dropdown-item,
      .clickable {
        cursor: pointer !important;
      }

      a[href] {
        cursor: pointer !important;
      }

      button:disabled,
      a.disabled,
      .disabled {
        cursor: not-allowed !important;
      }
    </style>

    <slot name="head" />
  </head>

  <body>
    <Header />

    <main class="main">
      <slot />
    </main>

    <Footer />

    <a href="#" id="scroll-top" class="scroll-top d-flex align-items-center justify-content-center">
      <i class="bi bi-arrow-up-short"></i>
    </a>

    <div id="preloader"></div>

    <script is:inline src="/assets/store/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
<script is:inline src="/assets/store/vendor/php-email-form/validate.js"></script>
<script is:inline src="/assets/store/vendor/swiper/swiper-bundle.min.js"></script>
<script is:inline src="/assets/store/vendor/aos/aos.js"></script>
<script is:inline src="/assets/store/vendor/drift-zoom/Drift.min.js"></script>
<script is:inline src="/assets/store/vendor/glightbox/js/glightbox.min.js"></script>
<script is:inline src="/assets/store/vendor/purecounter/purecounter_vanilla.js"></script>

<script is:inline src="/assets/store/js/main.js"></script>
  </body>
</html>