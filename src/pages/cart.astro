---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="cart - SmartStore" bodyClass="cart">

    <!-- Cart Section -->
    <section id="cart" class="cart section">

      <!-- Section Title -->
      <div class="container section-title" data-aos="fade-up">
        <h2>Cart</h2>
        <p>Necessitatibus eius consequatur ex aliquid fuga eum quidem sint consectetur velit</p>
      </div><!-- End Section Title -->

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row gy-4">
          <div class="col-lg-7" data-aos="fade-right" data-aos-delay="200">

            <div class="items-list">

              <!-- Cart Item 1 -->
              <div class="cart-item" data-aos="zoom-in" data-aos-delay="150">
                <button class="dismiss-btn remove-item" type="button">
                  <i class="bi bi-x-lg"></i>
                </button>
                <div class="row g-0 align-items-center">
                  <div class="col-md-3 col-4">
                    <div class="item-thumb">
                      <img src="assets/store/img/product/product-2.webp" alt="Product" class="img-fluid" loading="lazy">
                    </div>
                  </div>
                  <div class="col-md-9 col-8">
                    <div class="item-body">
                      <h6 class="item-name">Vestibulum ante ipsum primis</h6>
                      <div class="item-attributes">
                        <span class="attribute-badge">Color: Charcoal</span>
                        <span class="attribute-badge">Size: M</span>
                      </div>
                      <div class="item-bottom">
                        <div class="item-pricing">
                          <span class="unit-price">$89.99</span>
                        </div>
                        <div class="quantity-selector">
                          <button class="quantity-btn decrease"><i class="bi bi-dash"></i></button>
                          <input type="number" class="quantity-input" value="1" min="1" max="10">
                          <button class="quantity-btn increase"><i class="bi bi-plus"></i></button>
                        </div>
                        <div class="line-total">$89.99</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div><!-- End Cart Item -->

              <!-- Cart Item 2 -->
              <div class="cart-item" data-aos="zoom-in" data-aos-delay="250">
                <button class="dismiss-btn remove-item" type="button">
                  <i class="bi bi-x-lg"></i>
                </button>
                <div class="row g-0 align-items-center">
                  <div class="col-md-3 col-4">
                    <div class="item-thumb">
                      <img src="assets/store/img/product/product-6.webp" alt="Product" class="img-fluid" loading="lazy">
                    </div>
                  </div>
                  <div class="col-md-9 col-8">
                    <div class="item-body">
                      <h6 class="item-name">Pellentesque habitant morbi</h6>
                      <div class="item-attributes">
                        <span class="attribute-badge">Color: Ivory</span>
                        <span class="attribute-badge">Size: L</span>
                      </div>
                      <div class="item-bottom">
                        <div class="item-pricing">
                          <span class="unit-price">$64.99</span>
                          <span class="was-price">$79.99</span>
                        </div>
                        <div class="quantity-selector">
                          <button class="quantity-btn decrease"><i class="bi bi-dash"></i></button>
                          <input type="number" class="quantity-input" value="2" min="1" max="10">
                          <button class="quantity-btn increase"><i class="bi bi-plus"></i></button>
                        </div>
                        <div class="line-total">$129.98</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div><!-- End Cart Item -->

              <!-- Cart Item 3 -->
              <div class="cart-item" data-aos="zoom-in" data-aos-delay="350">
                <button class="dismiss-btn remove-item" type="button">
                  <i class="bi bi-x-lg"></i>
                </button>
                <div class="row g-0 align-items-center">
                  <div class="col-md-3 col-4">
                    <div class="item-thumb">
                      <img src="assets/store/img/product/product-8.webp" alt="Product" class="img-fluid" loading="lazy">
                    </div>
                  </div>
                  <div class="col-md-9 col-8">
                    <div class="item-body">
                      <h6 class="item-name">Maecenas tempus tellus eget</h6>
                      <div class="item-attributes">
                        <span class="attribute-badge">Color: Navy</span>
                        <span class="attribute-badge">Size: S</span>
                      </div>
                      <div class="item-bottom">
                        <div class="item-pricing">
                          <span class="unit-price">$49.99</span>
                        </div>
                        <div class="quantity-selector">
                          <button class="quantity-btn decrease"><i class="bi bi-dash"></i></button>
                          <input type="number" class="quantity-input" value="1" min="1" max="10">
                          <button class="quantity-btn increase"><i class="bi bi-plus"></i></button>
                        </div>
                        <div class="line-total">$49.99</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div><!-- End Cart Item -->

            </div>

            <div class="cart-toolbar" data-aos="fade-up" data-aos-delay="300">
              <a href="#" class="toolbar-link">
                <i class="bi bi-arrow-left"></i> Continue Shopping
              </a>
              <button class="toolbar-clear" type="button">
                <i class="bi bi-trash3"></i> Empty Cart
              </button>
            </div>

          </div>

          <div class="col-lg-5" data-aos="fade-left" data-aos-delay="300">
            <div class="order-panel">
              <div class="panel-header">
                <i class="bi bi-bag-check"></i>
                <h4>Order Overview</h4>
              </div>

              <div class="panel-body">

                <div class="promo-code">
                  <label class="promo-label">Have a promo code?</label>
                  <div class="input-group">
                    <input type="text" class="form-control" placeholder="Enter code">
                    <button class="btn apply-btn" type="button">Apply</button>
                  </div>
                </div>

                <div class="cost-breakdown">
                  <div class="cost-row">
                    <span class="cost-label">Subtotal (4 items)</span>
                    <span class="cost-amount">$269.96</span>
                  </div>

                  <div class="cost-row shipping-row">
                    <span class="cost-label">Delivery</span>
                    <div class="delivery-choices">
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="delivery" id="del-standard" checked="">
                        <label class="form-check-label" for="del-standard">Standard - $4.99</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="delivery" id="del-express">
                        <label class="form-check-label" for="del-express">Express - $12.99</label>
                      </div>
                      <div class="form-check">
                        <input class="form-check-input" type="radio" name="delivery" id="del-free">
                        <label class="form-check-label" for="del-free">Free (Orders $300+)</label>
                      </div>
                    </div>
                  </div>

                  <div class="cost-row">
                    <span class="cost-label">Estimated Tax</span>
                    <span class="cost-amount">$27.00</span>
                  </div>

                  <div class="cost-row savings">
                    <span class="cost-label">Savings</span>
                    <span class="cost-amount">-$0.00</span>
                  </div>
                </div>

                <div class="grand-total">
                  <span>Grand Total</span>
                  <span class="total-amount">$301.95</span>
                </div>

                <a href="#" class="btn checkout-btn">
                  Complete Purchase <i class="bi bi-cart-check"></i>
                </a>

                <div class="secure-badges">
                  <p class="badges-label">Secure Payment Methods</p>
                  <div class="badges-row">
                    <i class="bi bi-credit-card-2-front"></i>
                    <i class="bi bi-paypal"></i>
                    <i class="bi bi-shield-lock"></i>
                    <i class="bi bi-bank2"></i>
                  </div>
                </div>

              </div>
            </div>
          </div>
        </div>

      </div>

    </section><!-- /Cart Section -->
</BaseLayout>