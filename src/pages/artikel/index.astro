---
// src/pages/artikel/index.astro
export const prerender = true;

import BaseLayout from "../../layouts/BaseLayout.astro";
import { createClient } from '@supabase/supabase-js';

const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const { data: articles } = await supabase
  .from('articles')
  .select('*')
  .eq('status', 'published')
  .order('published_at', { ascending: false });

const categories = [...new Set((articles || []).map(a => a.category).filter(Boolean))];
const featured = articles?.[0];
const rest = articles?.slice(1) || [];

function formatDate(dateStr) {
  if (!dateStr) return '';
  return new Date(dateStr).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' });
}
---

<BaseLayout
  title="Blog & Artikel - ShopWise"
  description="Panduan belanja cerdas, review produk jujur, dan inspirasi gaya hidup dari tim ShopWise."
>
  <!-- Simple Hero -->
  <section class="blog-hero">
    <div class="container">
      <h1>Insights, Tips & Inspirasi</h1>
      <p>Panduan belanja cerdas, review produk jujur, dan inspirasi gaya hidup dari tim ShopWise.</p>
    </div>
  </section>

  <!-- Blog Content -->
  <section class="blog-section">
    <div class="container">

      <!-- Categories -->
      <div class="blog-categories" id="categoryFilter">
        <button class="cat-btn active" data-category="all">All Articles</button>
        {categories.map((cat) => (
          <button class="cat-btn" data-category={cat}>{cat}</button>
        ))}
      </div>

      <!-- Featured Article -->
      {featured && (
        <article class="featured-post" data-category={featured.category}>
          <div class="featured-wrapper">
            <div class="featured-image">
              <img 
                src={featured.cover_image || '/assets/store/img/product/product-placeholder.webp'} 
                alt={featured.title}
                loading="eager"
              />
            </div>
            <div class="featured-body">
              <span class="post-category">{featured.category}</span>
              <h2>
                <a href={`/artikel/${featured.slug}`}>{featured.title}</a>
              </h2>
              <p>{featured.excerpt}</p>
              <div class="post-meta">
                <span class="post-author">{featured.author_name || 'Admin'}</span>
                <span class="post-date">{formatDate(featured.published_at)}</span>
              </div>
            </div>
          </div>
        </article>
      )}

      <!-- Article Grid -->
      <div class="posts-grid">
        {rest.map((article) => (
          <article class="post-card" data-category={article.category}>
            <div class="post-image">
              <img 
                src={article.cover_image || '/assets/store/img/product/product-placeholder.webp'} 
                alt={article.title}
                loading="lazy"
              />
            </div>
            <div class="post-content">
              <span class="post-category">{article.category}</span>
              <h3>
                <a href={`/artikel/${article.slug}`}>{article.title}</a>
              </h3>
              <p>{article.excerpt}</p>
              <div class="post-meta">
                <span class="post-author">{article.author_name || 'Admin'}</span>
                <span class="post-date">{formatDate(article.published_at)}</span>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- Empty State -->
      {(!articles || articles.length === 0) && (
        <div class="empty-state">
          <p>Belum ada artikel yang dipublikasikan.</p>
        </div>
      )}

      

    </div>
  </section>

  <style is:global>
    /* Hero */
    .blog-hero {
      background: #f8f9fa;
      padding: 60px 0 50px;
      border-bottom: 1px solid #e9ecef;
      text-align: center;
    }

    .blog-hero h1 {
      font-size: 2.5rem;
      font-weight: 700;
      color: #212529;
      margin-bottom: 12px;
    }

    .blog-hero p {
      font-size: 1.1rem;
      color: #6c757d;
      max-width: 600px;
      margin: 0 auto;
    }

    /* Blog Section */
    .blog-section {
      padding: 50px 0 80px;
      background: #ffffff;
    }

    /* Categories */
    .blog-categories {
      display: flex;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 40px;
      padding-bottom: 20px;
      border-bottom: 1px solid #e9ecef;
    }

    .cat-btn {
      background: transparent;
      border: none;
      padding: 6px 16px;
      font-size: 14px;
      font-weight: 500;
      color: #6c757d;
      cursor: pointer;
      border-radius: 20px;
      transition: all 0.2s ease;
    }

    .cat-btn:hover {
      color: #212529;
      background: #f1f3f5;
    }

    .cat-btn.active {
      color: #212529;
      background: #e9ecef;
      font-weight: 600;
    }

    /* Featured Post */
    .featured-post {
      margin-bottom: 50px;
    }

    .featured-wrapper {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: center;
    }

    .featured-image {
      border-radius: 8px;
      overflow: hidden;
    }

    .featured-image img {
      width: 100%;
      height: 300px;
      object-fit: cover;
      display: block;
    }

    .featured-body h2 {
      font-size: 1.8rem;
      font-weight: 700;
      margin: 12px 0 16px;
      line-height: 1.3;
    }

    .featured-body h2 a {
      color: #212529;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .featured-body h2 a:hover {
      color: #0d6efd;
    }

    .featured-body p {
      color: #495057;
      line-height: 1.6;
      margin-bottom: 16px;
    }

    .post-category {
      display: inline-block;
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: #0d6efd;
      margin-bottom: 8px;
    }

    .post-meta {
      display: flex;
      gap: 16px;
      font-size: 14px;
      color: #6c757d;
    }

    .post-author {
      font-weight: 500;
      color: #212529;
    }

    /* Posts Grid */
    .posts-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 30px;
      margin-bottom: 60px;
    }

    .post-card {
      border-radius: 8px;
      overflow: hidden;
      transition: box-shadow 0.3s ease;
    }

    .post-card:hover {
      box-shadow: 0 4px 20px rgba(0,0,0,0.06);
    }

    .post-image {
      border-radius: 8px;
      overflow: hidden;
      margin-bottom: 16px;
    }

    .post-image img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      display: block;
      transition: transform 0.3s ease;
    }

    .post-card:hover .post-image img {
      transform: scale(1.03);
    }

    .post-content h3 {
      font-size: 1.15rem;
      font-weight: 600;
      margin: 8px 0 12px;
      line-height: 1.4;
    }

    .post-content h3 a {
      color: #212529;
      text-decoration: none;
      transition: color 0.2s ease;
    }

    .post-content h3 a:hover {
      color: #0d6efd;
    }

    .post-content p {
      color: #6c757d;
      font-size: 14px;
      line-height: 1.6;
      margin-bottom: 12px;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Newsletter */
    .newsletter-box {
      background: #f8f9fa;
      padding: 50px 40px;
      border-radius: 8px;
      text-align: center;
      margin-top: 20px;
    }

    .newsletter-box h3 {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .newsletter-box p {
      color: #6c757d;
      margin-bottom: 20px;
    }

    .newsletter-form {
      display: flex;
      max-width: 450px;
      margin: 0 auto;
      gap: 10px;
    }

    .newsletter-form input {
      flex: 1;
      padding: 10px 16px;
      border: 1px solid #dee2e6;
      border-radius: 6px;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s ease;
    }

    .newsletter-form input:focus {
      border-color: #0d6efd;
    }

    .newsletter-form button {
      padding: 10px 28px;
      background: #212529;
      color: white;
      border: none;
      border-radius: 6px;
      font-weight: 600;
      font-size: 14px;
      cursor: pointer;
      transition: background 0.2s ease;
      white-space: nowrap;
    }

    .newsletter-form button:hover {
      background: #0d6efd;
    }

    /* Empty State */
    .empty-state {
      text-align: center;
      padding: 60px 20px;
      color: #6c757d;
    }

    /* Responsive */
    @media (max-width: 992px) {
      .featured-wrapper {
        grid-template-columns: 1fr;
        gap: 24px;
      }

      .featured-image img {
        height: 250px;
      }

      .posts-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .blog-hero {
        padding: 40px 0 30px;
      }

      .blog-hero h1 {
        font-size: 2rem;
      }

      .posts-grid {
        grid-template-columns: 1fr;
        gap: 30px;
      }

      .featured-body h2 {
        font-size: 1.4rem;
      }

      .newsletter-box {
        padding: 30px 20px;
      }

      .newsletter-form {
        flex-direction: column;
      }

      .blog-categories {
        gap: 6px;
      }

      .cat-btn {
        padding: 4px 12px;
        font-size: 13px;
      }
    }

    @media (max-width: 576px) {
      .blog-hero h1 {
        font-size: 1.6rem;
      }

      .featured-image img {
        height: 200px;
      }

      .post-image img {
        height: 180px;
      }
    }
  </style>

  <script>
    // Category Filter
    document.querySelectorAll('.cat-btn').forEach((btn) => {
      btn.addEventListener('click', function() {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        this.classList.add('active');

        const selected = this.dataset.category;
        document.querySelectorAll('.post-card, .featured-post').forEach((el) => {
          const cat = el.dataset.category;
          el.style.display = (selected === 'all' || cat === selected) ? '' : 'none';
        });
      });
    });
  </script>
</BaseLayout>