---
// @ts-nocheck
// src/pages/account.astro
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="My Account - SmartStore">

  <div id="account-loading" class="container py-5 text-center">
    <div class="spinner-border text-primary" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
    <p class="mt-3">Loading account...</p>
  </div>

  <div id="account-content" style="display: none;">
    <!-- Page Title -->
    <div class="page-title light-background">
      <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">My Account</h1>
        <nav class="breadcrumbs">
          <ol>
            <li><a href="/">Home</a></li>
            <li class="current">Account</li>
          </ol>
        </nav>
      </div>
    </div>

    <!-- Account Section -->
    <section id="account" class="account section">
      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <!-- Account Banner -->
        <div class="account-banner" data-aos="zoom-in" data-aos-delay="100">
          <div class="row align-items-center g-3">
            <div class="col-auto">
              <div class="avatar-wrap">
                <div id="userAvatar" class="avatar-placeholder" style="width: 70px; height: 70px; border-radius: 50%; background: #4e73df; display: flex; align-items: center; justify-content: center; font-size: 28px; color: white;">
                  U
                </div>
                <span class="verified-mark"><i class="bi bi-patch-check-fill"></i></span>
              </div>
            </div>
            <div class="col">
              <h3 id="userName" class="user-name">User</h3>
              <div class="member-tag"><i class="bi bi-gem"></i> Member</div>
            </div>
            <div class="col-md-auto d-none d-md-flex">
              <div class="stat-pills">
                <div class="pill-item"><span id="orderCount" class="pill-val">0</span><span class="pill-txt">Orders</span></div>
                <div class="pill-item"><span id="trackCount" class="pill-val">0</span><span class="pill-txt">Tracking</span></div>
                <div class="pill-item"><span id="wishlistCount" class="pill-val">0</span><span class="pill-txt">Saved</span></div>
                <div class="pill-item"><span id="reviewCount" class="pill-val">0</span><span class="pill-txt">Reviews</span></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Tab Navigation -->
        <div class="tab-strip" data-aos="fade-up" data-aos-delay="150">
          <div class="tab-strip-inner">
            <ul class="nav" role="tablist">
              <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" data-bs-target="#account-tab-track"><i class="bi bi-truck"></i><span>Track Order</span></a></li>
              <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" data-bs-target="#account-tab-orders"><i class="bi bi-bag"></i><span>Orders</span></a></li>
              <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" data-bs-target="#account-tab-reviews"><i class="bi bi-star"></i><span>Reviews</span></a></li>
              <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" data-bs-target="#account-tab-wishlist"><i class="bi bi-bookmark-heart"></i><span>Favorites</span></a></li>
              <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" data-bs-target="#account-tab-settings"><i class="bi bi-sliders"></i><span>Preferences</span></a></li>
            </ul>
            <div class="strip-actions d-none d-lg-flex">
              <button id="logoutBtn" class="strip-link sign-out">
                <i class="bi bi-power"></i> Sign Out
              </button>
            </div>
          </div>
        </div>

        <!-- Tab Content -->
        <div class="tab-content panel-area">

          <!-- Orders Tab -->
          <div class="tab-pane fade show active" id="account-tab-orders">
            <div class="panel-header" data-aos="fade-up">
              <h2>Purchase History</h2>
            </div>
            <div id="ordersList" class="order-list">
              <div class="text-center py-5">
                <p class="text-muted">Loading orders...</p>
              </div>
            </div>
          </div>

          <!-- Track Order Tab -->
          <div class="tab-pane fade" id="account-tab-track">
            <div class="panel-header" data-aos="fade-up">
              <h2>Track Order</h2>
              <p class="text-muted">Pesanan yang sedang diproses</p>
            </div>
            <div id="trackList" class="order-list">
              <div class="text-center py-5">
                <p class="text-muted">Loading tracking...</p>
              </div>
            </div>
          </div>

          <!-- Reviews Tab -->
          <div class="tab-pane fade" id="account-tab-reviews">
            <div class="panel-header" data-aos="fade-up">
              <h2>My Reviews</h2>
            </div>
            <div id="reviewsList" class="review-list">
              <div class="text-center py-5">
                <p class="text-muted">Loading reviews...</p>
              </div>
            </div>
          </div>

          <!-- Favorites Tab (Wishlist) -->
          <div class="tab-pane fade" id="account-tab-wishlist">
            <div class="panel-header" data-aos="fade-up">
              <h2>Saved Favorites</h2>
            </div>
            <div id="wishlistList" class="wishlist-list">
              <div class="text-center py-5">
                <p class="text-muted">Loading wishlist...</p>
              </div>
            </div>
          </div>

          <!-- Preferences Tab -->
          <div class="tab-pane fade" id="account-tab-settings">
            <div class="panel-header" data-aos="fade-up">
              <h2>Account Preferences</h2>
            </div>
            <div class="prefs-grid">
              <div class="pref-section" data-aos="fade-up">
                <h3><i class="bi bi-person-circle"></i> Personal Details</h3>
                <form id="profileForm">
                  <div class="row g-3">
                    <div class="col-12">
                      <label for="fullName" class="form-label">Full Name</label>
                      <input type="text" class="form-control" id="fullName" required />
                    </div>
                    <div class="col-12">
                      <label for="phone" class="form-label">Phone Number</label>
                      <input type="tel" class="form-control" id="phone" />
                    </div>
                    <div class="col-12">
                      <label for="address" class="form-label">Address</label>
                      <textarea class="form-control" id="address" rows="3"></textarea>
                    </div>
                  </div>
                  <div id="profileErrorMsg" class="alert alert-danger d-none mt-3"></div>
                  <div id="profileSuccessMsg" class="alert alert-success d-none mt-3"></div>
                  <div class="pref-form-footer mt-3">
                    <button type="submit" class="btn-filled-action" id="profileBtn">
                      <span id="profileText">Save Changes</span>
                      <span id="profileSpinner" class="spinner-border spinner-border-sm d-none"></span>
                    </button>
                  </div>
                </form>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>
  </div>

  <script>
    //@ts-nocheck
    import { supabase } from "@/lib/supabase/client";

    const loadingEl = document.getElementById('account-loading');
    const contentEl = document.getElementById('account-content');

    async function loadAccount() {
      try {
        // Cek session
        const { data: { session } } = await supabase.auth.getSession();
        
        if (!session) {
          window.location.href = '/login';
          return;
        }

        // Ambil profile
        const { data: profile } = await supabase
          .from('profiles')
          .select('*')
          .eq('id', session.user.id)
          .single();

        // Ambil semua orders
        const { data: orders } = await supabase
          .from('orders')
          .select('*')
          .eq('user_id', session.user.id)
          .order('created_at', { ascending: false })
          .limit(20);

        // Filter order aktif (belum selesai)
        const activeStatuses = ['pending', 'paid', 'processing', 'shipped'];
        const trackOrders = orders?.filter(o => activeStatuses.includes(o.status)) || [];

        const { count: orderCount } = await supabase
          .from('orders')
          .select('*', { count: 'exact', head: true })
          .eq('user_id', session.user.id);

        // Ambil reviews
        const { data: reviews, count: reviewCount } = await supabase
          .from('reviews')
          .select(`
            *,
            products (
              id,
              name,
              slug,
              image_url
            )
          `, { count: 'exact' })
          .eq('user_id', session.user.id)
          .order('created_at', { ascending: false });

        // ===== AMBIL WISHLIST =====
        const { data: wishlistItems, count: wishlistCount } = await supabase
          .from('wishlists')
          .select(`
            id,
            product_id,
            products (
              id,
              name,
              slug,
              price,
              discount,
              image_url
            )
          `, { count: 'exact' })
          .eq('user_id', session.user.id)
          .order('created_at', { ascending: false });

        // ===== UPDATE UI =====
        const firstName = (profile as any)?.full_name || 'User';
        const userNameEl = document.getElementById('userName');
        const userAvatarEl = document.getElementById('userAvatar');
        const orderCountEl = document.getElementById('orderCount');
        const trackCountEl = document.getElementById('trackCount');
        const wishlistCountEl = document.getElementById('wishlistCount');
        const reviewCountEl = document.getElementById('reviewCount');
        if (userNameEl) userNameEl.textContent = firstName;
        if (userAvatarEl) userAvatarEl.textContent = firstName.charAt(0);
        if (orderCountEl) orderCountEl.textContent = String(orderCount || 0);
        if (trackCountEl) trackCountEl.textContent = String(trackOrders?.length || 0);
        if (wishlistCountEl) wishlistCountEl.textContent = String(wishlistCount || 0);
        if (reviewCountEl) reviewCountEl.textContent = String(reviewCount || 0);

        // ===== ISI FORM PROFILE =====
        const fullNameEl = document.getElementById('fullName');
        const phoneEl = document.getElementById('phone');
        const addressEl = document.getElementById('address');
        if (fullNameEl) fullNameEl.value = (profile as any)?.full_name || '';
        if (phoneEl) phoneEl.value = (profile as any)?.phone || '';
        if (addressEl) addressEl.value = (profile as any)?.address || '';

        // ===== RENDER ORDERS =====
        const ordersList = document.getElementById('ordersList');
        if (ordersList) {
          if (orders && orders.length > 0) {
            ordersList.innerHTML = (orders as any[]).map((order) => `
              <div class="order-row status-processing" data-aos="fade-up" data-order-id="${order.id}">
                <div class="row align-items-center g-3">
                  <div class="col-lg-5">
                    <div class="order-main">
                      <div class="order-brief">
                        <span class="order-ref">#${order.id.slice(0, 8)}</span>
                        <span class="order-when">${new Date(order.created_at).toLocaleDateString('id-ID')}</span>
                      </div>
                    </div>
                  </div>
                  <div class="col-6 col-lg-2 text-center">
                    <span class="status-pill ${order.status === 'delivered' ? 'delivered' : order.status === 'cancelled' ? 'cancelled' : 'processing'}">
                      ${order.status}
                    </span>
                  </div>
                  <div class="col-6 col-lg-2 text-center">
                    <span class="order-total">Rp ${order.total.toLocaleString('id-ID')}</span>
                  </div>
                  <div class="col-lg-3">
                    <div class="order-actions">
                      <button type="button" class="btn-outline-action track-btn" data-order-id="${order.id}">
                        <i class="bi bi-truck"></i> Track
                      </button>
                      <button type="button" class="btn-filled-action detail-btn" data-order-id="${order.id}">
                        <i class="bi bi-eye"></i> Details
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            `).join('');

            document.querySelectorAll('.track-btn').forEach((btn) => {
              btn.addEventListener('click', function() {
                const orderId = this.dataset.orderId;
                window.location.href = `/order-confirmation?order=${orderId}`;
              });
            });

            document.querySelectorAll('.detail-btn').forEach((btn) => {
              btn.addEventListener('click', function() {
                const orderId = this.dataset.orderId;
                window.location.href = `/order-confirmation?order=${orderId}`;
              });
            });

          } else {
            ordersList.innerHTML = `
              <div class="text-center py-5">
                <p class="text-muted">Belum ada pesanan.</p>
                <a href="/category" class="btn btn-primary">Mulai Belanja</a>
              </div>
            `;
          }
        }

        // ===== RENDER TRACK ORDERS =====
        const trackList = document.getElementById('trackList');
        if (trackList) {
          if (trackOrders && trackOrders.length > 0) {
            trackList.innerHTML = (trackOrders as any[]).map((order) => `
              <div class="order-row status-processing" data-aos="fade-up" data-order-id="${order.id}">
                <div class="row align-items-center g-3">
                  <div class="col-lg-5">
                    <div class="order-main">
                      <div class="order-brief">
                        <span class="order-ref">#${order.id.slice(0, 8)}</span>
                        <span class="order-when">${new Date(order.created_at).toLocaleDateString('id-ID')}</span>
                      </div>
                    </div>
                  </div>
                  <div class="col-6 col-lg-2 text-center">
                    <span class="status-pill processing">
                      ${order.status}
                    </span>
                  </div>
                  <div class="col-6 col-lg-2 text-center">
                    <span class="order-total">Rp ${order.total.toLocaleString('id-ID')}</span>
                  </div>
                  <div class="col-lg-3">
                    <div class="order-actions">
                      <button type="button" class="btn-outline-action track-btn" data-order-id="${order.id}">
                        <i class="bi bi-truck"></i> Track
                      </button>
                      <button type="button" class="btn-filled-action detail-btn" data-order-id="${order.id}">
                        <i class="bi bi-eye"></i> Details
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            `).join('');

            document.querySelectorAll('.track-btn').forEach((btn) => {
              btn.addEventListener('click', function() {
                const orderId = this.dataset.orderId;
                window.location.href = `/order-confirmation?order=${orderId}`;
              });
            });

            document.querySelectorAll('.detail-btn').forEach((btn) => {
              btn.addEventListener('click', function() {
                const orderId = this.dataset.orderId;
                window.location.href = `/order-confirmation?order=${orderId}`;
              });
            });

          } else {
            trackList.innerHTML = `
              <div class="text-center py-5">
                <i class="bi bi-check-circle" style="font-size: 48px; color: #28a745;"></i>
                <h5 class="mt-3">Tidak ada pesanan aktif</h5>
                <p class="text-muted">Semua pesanan sudah selesai atau tidak ada pesanan.</p>
                <a href="/category" class="btn btn-primary">Belanja Sekarang</a>
              </div>
            `;
          }
        }

        // ===== RENDER REVIEWS =====
        const reviewsList = document.getElementById('reviewsList');
        if (reviewsList) {
          if (reviews && reviews.length > 0) {
            reviewsList.innerHTML = (reviews as any[]).map((review) => {
              const stars = renderStarsHTML(review.rating);
              return `
                <div class="review-item" data-aos="fade-up" style="border-bottom: 1px solid #eee; padding: 20px 0;">
                  <div class="row">
                    <div class="col-md-3">
                      <img 
                        src="${review.products?.image_url || '/assets/store/img/product/product-placeholder.webp'}" 
                        alt="${review.products?.name || 'Product'}" 
                        style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;"
                      />
                    </div>
                    <div class="col-md-9">
                      <h5>
                        <a href="/product-details?slug=${review.products?.slug}" style="color: #212529; text-decoration: none;">
                          ${review.products?.name || 'Product'}
                        </a>
                      </h5>
                      <div class="stars">${stars}</div>
                      <p class="mt-2">${review.comment || 'No comment'}</p>
                      <small class="text-muted">${new Date(review.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</small>
                      <div class="mt-2">
                        <button class="btn btn-sm btn-outline-danger delete-review-btn" data-review-id="${review.id}">
                          <i class="bi bi-trash"></i> Hapus
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              `;
            }).join('');

            document.querySelectorAll('.delete-review-btn').forEach((btn) => {
              btn.addEventListener('click', async function() {
                const reviewId = this.dataset.reviewId;
                if (!confirm('Apakah Anda yakin ingin menghapus review ini?')) return;

                const { error } = await supabase
                  .from('reviews')
                  .delete()
                  .eq('id', reviewId);

                if (error) {
                  alert('Gagal menghapus review: ' + error.message);
                } else {
                  alert('Review berhasil dihapus!');
                  window.location.reload();
                }
              });
            });

          } else {
            reviewsList.innerHTML = `
              <div class="text-center py-5">
                <p class="text-muted">Belum ada review.</p>
                <a href="/category" class="btn btn-primary">Belanja Sekarang</a>
              </div>
            `;
          }
        }

        // ===== RENDER WISHLIST =====
        const wishlistList = document.getElementById('wishlistList');
        if (wishlistList) {
          if (wishlistItems && wishlistItems.length > 0) {
            wishlistList.innerHTML = (wishlistItems as any[]).map((item) => {
              const product = item.products;
              const price = product?.price || 0;
              const discount = product?.discount || 0;
              const discountedPrice = price * (1 - discount / 100);
              
              return `
                <div class="wishlist-item" data-aos="fade-up" style="border-bottom: 1px solid #eee; padding: 20px 0;">
                  <div class="row align-items-center">
                    <div class="col-md-2">
                      <img 
                        src="${product?.image_url || '/assets/store/img/product/product-placeholder.webp'}" 
                        alt="${product?.name || 'Product'}" 
                        style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;"
                      />
                    </div>
                    <div class="col-md-5">
                      <h5>
                        <a href="/product-details?slug=${product?.slug}" style="color: #212529; text-decoration: none;">
                          ${product?.name || 'Product'}
                        </a>
                      </h5>
                      <div class="text-muted small">
                        ${discount > 0 ? `
                          <span class="text-decoration-line-through">Rp ${price.toLocaleString('id-ID')}</span>
                          <span class="text-danger fw-bold">Rp ${discountedPrice.toLocaleString('id-ID')}</span>
                        ` : `
                          <span class="fw-bold">Rp ${price.toLocaleString('id-ID')}</span>
                        `}
                      </div>
                    </div>
                    <div class="col-md-5 text-end">
                      <button class="btn btn-sm btn-outline-primary add-to-cart-wishlist" data-product-id="${product?.id}">
                        <i class="bi bi-cart-plus me-1"></i>Add to Cart
                      </button>
                      <button class="btn btn-sm btn-outline-danger remove-wishlist-btn" data-wishlist-id="${item.id}">
                        <i class="bi bi-trash"></i>
                      </button>
                    </div>
                  </div>
                </div>
              `;
            }).join('');

            // ===== REMOVE FROM WISHLIST =====
            document.querySelectorAll('.remove-wishlist-btn').forEach((btn) => {
              btn.addEventListener('click', async function() {
                const wishlistId = this.dataset.wishlistId;
                if (!confirm('Hapus dari favorit?')) return;

                const { error } = await supabase
                  .from('wishlists')
                  .delete()
                  .eq('id', wishlistId);

                if (!error) {
                  alert('Produk dihapus dari favorit!');
                  window.location.reload();
                }
              });
            });

            // ===== ADD TO CART FROM WISHLIST =====
            document.querySelectorAll('.add-to-cart-wishlist').forEach((btn) => {
              btn.addEventListener('click', async function() {
                const productId = this.dataset.productId;
                const { data: { session } } = await supabase.auth.getSession();
                if (!session) {
                  window.location.href = '/login';
                  return;
                }

                const { error } = await supabase
                  .from('cart')
                  .insert({
                    user_id: session.user.id,
                    product_id: productId,
                    quantity: 1
                  });

                if (error) {
                  alert('Gagal menambahkan ke keranjang');
                } else {
                  alert('Produk ditambahkan ke keranjang!');
                  document.dispatchEvent(new Event('cartUpdated'));
                  window.location.reload();
                }
              });
            });

          } else {
            wishlistList.innerHTML = `
              <div class="text-center py-5">
                <i class="bi bi-heart" style="font-size: 48px; color: #dee2e6;"></i>
                <h5 class="mt-3">Belum ada produk favorit</h5>
                <p class="text-muted">Mulai tambahkan produk ke favoritmu!</p>
                <a href="/category" class="btn btn-primary">Cari Produk</a>
              </div>
            `;
          }
        }

        // Tampilkan content, hide loading
        if (loadingEl) loadingEl.style.display = 'none';
        if (contentEl) contentEl.style.display = 'block';

      } catch (error) {
        console.error('Error loading account:', error);
        window.location.href = '/login';
      }
    }

    // ===== HELPER RENDER STARS =====
    function renderStarsHTML(rating) {
      const fullStars = Math.floor(rating);
      const hasHalfStar = rating % 1 >= 0.5;
      let html = '';
      for (let i = 0; i < fullStars; i++) {
        html += '<i class="bi bi-star-fill" style="color: #f59e0b;"></i>';
      }
      if (hasHalfStar) {
        html += '<i class="bi bi-star-half" style="color: #f59e0b;"></i>';
      }
      while (html.split('<i').length - 1 < 5) {
        html += '<i class="bi bi-star" style="color: #ddd;"></i>';
      }
      return html;
    }

    // ===== LOGOUT =====
    document.getElementById('logoutBtn')?.addEventListener('click', async () => {
      try {
        await supabase.auth.signOut();
        window.location.href = '/';
      } catch (error) {
        console.error('Logout error:', error);
      }
    });

    // ===== UPDATE PROFILE =====
    document.getElementById('profileForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const errorMsg = document.getElementById('profileErrorMsg');
      const successMsg = document.getElementById('profileSuccessMsg');
      const btn = document.getElementById('profileBtn');
      const text = document.getElementById('profileText');
      const spinner = document.getElementById('profileSpinner');

      errorMsg?.classList.add('d-none');
      successMsg?.classList.add('d-none');
      btn?.setAttribute('disabled', 'true');
      if (text) text.classList.add('d-none');
      if (spinner) spinner.classList.remove('d-none');

      const fullName = (document.getElementById('fullName') as HTMLInputElement)?.value || '';
      const phone = (document.getElementById('phone') as HTMLInputElement)?.value || '';
      const address = (document.getElementById('address') as HTMLTextAreaElement)?.value || '';

      const { data: { user } } = await supabase.auth.getUser();

      if (user) {
        // @ts-ignore
        const { error } = await supabase
          .from('profiles')
          .update({ full_name: fullName, phone: phone, address: address })
          .eq('id', user.id);

        if (error) {
          if (errorMsg) {
            errorMsg.textContent = error.message;
            errorMsg.classList.remove('d-none');
          }
        } else {
          if (successMsg) {
            successMsg.textContent = 'Profile berhasil diupdate!';
            successMsg.classList.remove('d-none');
          }
          const userNameEl2 = document.getElementById('userName');
          const userAvatarEl2 = document.getElementById('userAvatar');
          if (userNameEl2) userNameEl2.textContent = fullName;
          if (userAvatarEl2) userAvatarEl2.textContent = fullName.charAt(0);
        }
      }

      btn?.removeAttribute('disabled');
      if (text) text.classList.remove('d-none');
      if (spinner) spinner.classList.add('d-none');
    });

    // ===== JALANKAN =====
    loadAccount();

    // ===== BUKA TAB BERDASARKAN PARAMETER URL =====
    (function openTabFromUrl() {
      const urlParams = new URLSearchParams(window.location.search);
      const tab = urlParams.get('tab');
      
      const tabMap = {
        'orders': 'account-tab-orders',
        'track': 'account-tab-track',
        'reviews': 'account-tab-reviews',
        'wishlist': 'account-tab-wishlist',
        'settings': 'account-tab-settings'
      };
      
      const targetId = tabMap[tab];
      if (targetId) {
        setTimeout(() => {
          const targetTab = document.querySelector(`[data-bs-target="#${targetId}"]`);
          if (targetTab) {
            document.querySelectorAll('.nav-link').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('show', 'active'));
            targetTab.classList.add('active');
            const target = document.getElementById(targetId);
            if (target) target.classList.add('show', 'active');
          }
        }, 100);
      }
    })();
  </script>
</BaseLayout>