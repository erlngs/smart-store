---
// @ts-nocheck
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { isUserAdmin } from "../../lib/supabase/server";

const { supabase, user } = Astro.locals;

if (!user) {
  return Astro.redirect('/admin/login');
}
const isAdmin = await isUserAdmin(supabase, user.id);
if (!isAdmin) {
  return Astro.redirect('/admin/login');
}

const { data: articles } = await supabase
  .from('articles')
  .select('*')
  .order('created_at', { ascending: false });
---

<AdminLayout title="Articles - SmartStore Admin">

  <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Articles Management</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#articleModal" id="addArticleBtn">
      <i class="bi bi-plus-lg me-1"></i> Add New Article
    </button>
  </div>

  <div class="card shadow mb-4">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered" width="100%" cellspacing="0">
          <thead>
            <tr>
              <th>Cover</th>
              <th>Title</th>
              <th>Category</th>
              <th>Author</th>
              <th>Status</th>
              <th>Published</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            {articles && articles.length > 0 ? (
              articles.map((a) => (
                <tr>
                  <td>
                    <img src={a.cover_image || '/assets/store/img/product/product-placeholder.webp'} style="width: 60px; height: 45px; object-fit: cover; border-radius: 6px;" />
                  </td>
                  <td>
                    <strong>{a.title}</strong><br />
                    <small class="text-muted">/{a.slug}</small>
                  </td>
                  <td>{a.category ? <span class="badge bg-secondary">{a.category}</span> : '-'}</td>
                  <td>{a.author_name}</td>
                  <td>
                    {a.status === 'published' ? (
                      <span class="badge bg-success">Published</span>
                    ) : (
                      <span class="badge bg-warning text-dark">Draft</span>
                    )}
                  </td>
                  <td>{a.published_at ? new Date(a.published_at).toLocaleDateString('id-ID') : '-'}</td>
                  <td>
                    <button class="btn btn-sm btn-outline-primary edit-article-btn" data-id={a.id} data-bs-toggle="modal" data-bs-target="#articleModal">
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger delete-article-btn" data-id={a.id}>
                      <i class="bi bi-trash"></i>
                    </button>
                  </td>
                </tr>
              ))
            ) : (
              <tr><td colspan="7" class="text-center py-4">No articles yet</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Modal Add/Edit Article -->
  <div class="modal fade" id="articleModal" tabindex="-1">
    <div class="modal-dialog modal-xl">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="articleModalTitle"><i class="bi bi-file-earmark-text me-2"></i>Add New Article</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="articleForm">
          <input type="hidden" id="articleId">
          <div class="modal-body">
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label">Title</label>
                <input type="text" class="form-control" id="articleTitle" required>
              </div>
              <div class="col-md-4">
                <label class="form-label">Slug (URL)</label>
                <input type="text" class="form-control" id="articleSlug" placeholder="auto-generated" required>
              </div>

              <div class="col-md-4">
                <label class="form-label">Category</label>
                <select class="form-select" id="articleCategory">
                  <option value="Tips">Tips & Tricks</option>
                  <option value="Review">Product Review</option>
                  <option value="Inspirasi">Inspirasi</option>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label">Author</label>
                <input type="text" class="form-control" id="articleAuthor" value="Admin">
              </div>
              <div class="col-md-4">
                <label class="form-label">Status</label>
                <select class="form-select" id="articleStatus">
                  <option value="draft">Draft</option>
                  <option value="published">Published</option>
                </select>
              </div>

              <div class="col-12">
                <label class="form-label">Cover Image</label>
                <input type="file" class="form-control" id="articleCoverFile" accept="image/*">
                <input type="hidden" id="articleCoverUrl">
                <img id="articleCoverPreview" src="" style="display:none; max-height: 120px; margin-top: 8px; border-radius: 8px;">
              </div>

              <div class="col-12">
                <label class="form-label">Excerpt (ringkasan singkat, tampil di list & meta description default)</label>
                <textarea class="form-control" id="articleExcerpt" rows="2"></textarea>
              </div>

              <div class="col-12">
                <label class="form-label">Content</label>
                <div id="articleEditor" style="height: 300px; background: white;"></div>
              </div>

              <div class="col-12"><hr><h6>SEO Settings (opsional, kosongkan untuk pakai default)</h6></div>
              <div class="col-md-6">
                <label class="form-label">Meta Title</label>
                <input type="text" class="form-control" id="articleMetaTitle">
              </div>
              <div class="col-md-6">
                <label class="form-label">Meta Description</label>
                <input type="text" class="form-control" id="articleMetaDescription">
              </div>
              <div class="col-12">
                <label class="form-label">Tags (pisahkan dengan koma)</label>
                <input type="text" class="form-control" id="articleTags" placeholder="dekorasi rumah, minimalis, interior">
              </div>
            </div>
            <div id="articleFormError" class="alert alert-danger d-none mt-3"></div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary" id="saveArticleBtn">Save Article</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Quill CDN -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.snow.min.css" rel="stylesheet">
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/quill/1.3.7/quill.min.js"></script>

  <script>
    //@ts-nocheck
    import { supabaseAdmin as supabase } from "@/lib/supabase/client";

    let quill;
    document.addEventListener('DOMContentLoaded', () => {
      quill = new Quill('#articleEditor', { theme: 'snow' });
    });

    function slugify(text) {
      return text.toLowerCase().trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
    }

    function calcReadingTime(html) {
      const text = html.replace(/<[^>]*>/g, ' ');
      const words = text.trim().split(/\s+/).length;
      return Math.max(1, Math.ceil(words / 200));
    }

    document.getElementById('articleTitle')?.addEventListener('input', function() {
      const slugField = document.getElementById('articleSlug');
      if (!slugField.dataset.manuallyEdited) {
        slugField.value = slugify(this.value);
      }
    });
    document.getElementById('articleSlug')?.addEventListener('input', function() {
      this.dataset.manuallyEdited = 'true';
    });

    // Upload cover preview
    document.getElementById('articleCoverFile')?.addEventListener('change', async function() {
      const file = this.files[0];
      if (!file) return;
      const preview = document.getElementById('articleCoverPreview');
      preview.src = URL.createObjectURL(file);
      preview.style.display = 'block';
    });

    // Reset form saat buka modal untuk "Add New"
    document.getElementById('addArticleBtn')?.addEventListener('click', () => {
      document.getElementById('articleModalTitle').textContent = 'Add New Article';
      document.getElementById('articleForm').reset();
      document.getElementById('articleId').value = '';
      document.getElementById('articleCoverUrl').value = '';
      document.getElementById('articleCoverPreview').style.display = 'none';
      document.getElementById('articleSlug').dataset.manuallyEdited = '';
      if (quill) quill.setContents([]);
    });

    // Edit article
    document.querySelectorAll('.edit-article-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const id = this.dataset.id;
        const { data: article } = await supabase.from('articles').select('*').eq('id', id).single();
        if (!article) return;

        document.getElementById('articleModalTitle').textContent = 'Edit Article';
        document.getElementById('articleId').value = article.id;
        document.getElementById('articleTitle').value = article.title;
        document.getElementById('articleSlug').value = article.slug;
        document.getElementById('articleSlug').dataset.manuallyEdited = 'true';
        document.getElementById('articleCategory').value = article.category || 'Tips';
        document.getElementById('articleAuthor').value = article.author_name || 'Admin';
        document.getElementById('articleStatus').value = article.status;
        document.getElementById('articleExcerpt').value = article.excerpt || '';
        document.getElementById('articleMetaTitle').value = article.meta_title || '';
        document.getElementById('articleMetaDescription').value = article.meta_description || '';
        document.getElementById('articleTags').value = (article.tags || []).join(', ');
        document.getElementById('articleCoverUrl').value = article.cover_image || '';

        const preview = document.getElementById('articleCoverPreview');
        if (article.cover_image) {
          preview.src = article.cover_image;
          preview.style.display = 'block';
        } else {
          preview.style.display = 'none';
        }

        if (quill) quill.root.innerHTML = article.content || '';
      });
    });

    // Delete article
    document.querySelectorAll('.delete-article-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        if (!confirm('Delete this article?')) return;
        const id = this.dataset.id;
        const { error } = await supabase.from('articles').delete().eq('id', id);
        if (error) { alert('Error: ' + error.message); return; }
        window.location.reload();
      });
    });

    // Submit form (Add or Edit)
    document.getElementById('articleForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById('articleFormError');
      errorEl.classList.add('d-none');

      const id = document.getElementById('articleId').value;
      const title = document.getElementById('articleTitle').value;
      const slug = document.getElementById('articleSlug').value;
      const category = document.getElementById('articleCategory').value;
      const author_name = document.getElementById('articleAuthor').value;
      const status = document.getElementById('articleStatus').value;
      const excerpt = document.getElementById('articleExcerpt').value;
      const meta_title = document.getElementById('articleMetaTitle').value || null;
      const meta_description = document.getElementById('articleMetaDescription').value || null;
      const tags = document.getElementById('articleTags').value
        .split(',').map(t => t.trim()).filter(Boolean);
      const content = quill ? quill.root.innerHTML : '';
      const reading_time = calcReadingTime(content);

      let cover_image = document.getElementById('articleCoverUrl').value || null;
      const coverFile = document.getElementById('articleCoverFile').files[0];

      if (coverFile) {
        const fileExt = coverFile.name.split('.').pop();
        const fileName = `cover_${slug}_${Date.now()}.${fileExt}`;
        const { error: uploadError } = await supabase.storage
          .from('article-covers')
          .upload(fileName, coverFile, { cacheControl: '3600', upsert: false });

        if (uploadError) {
          errorEl.textContent = 'Gagal upload cover: ' + uploadError.message;
          errorEl.classList.remove('d-none');
          return;
        }

        const { data: urlData } = supabase.storage.from('article-covers').getPublicUrl(fileName);
        cover_image = urlData.publicUrl;
      }

      const payload = {
        title, slug, category, author_name, status, excerpt,
        meta_title, meta_description, tags, content, reading_time,
        cover_image,
        published_at: status === 'published' ? new Date().toISOString() : null,
        updated_at: new Date().toISOString()
      };

      let error;
      if (id) {
        ({ error } = await supabase.from('articles').update(payload).eq('id', id));
      } else {
        ({ error } = await supabase.from('articles').insert(payload));
      }

      if (error) {
        errorEl.textContent = error.message;
        errorEl.classList.remove('d-none');
        return;
      }

      window.location.reload();
    });
  </script>

</AdminLayout>