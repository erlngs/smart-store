---
// @ts-nocheck
// src/pages/admin/products.astro
export const prerender = false;

import AdminLayout from "../../layouts/AdminLayout.astro";
import { isUserAdmin } from "../../lib/supabase/server";

const { supabase, user } = Astro.locals;

// Proteksi: harus login & admin
if (!user) {
  return Astro.redirect('/admin/login');
}
const isAdmin = await isUserAdmin(supabase, user.id);
if (!isAdmin) {
  return Astro.redirect('/admin/login');
}

// Ambil semua produk
const { data: products } = await supabase
  .from('products')
  .select('*')
  .order('created_at', { ascending: false });

let productsWithVariants = [];
if (products && products.length > 0) {
  const productIds = products.map(p => p.id);
  const { data: allVariants } = await supabase
    .from('product_variants')
    .select('*')
    .in('product_id', productIds);

  productsWithVariants = products.map(p => ({
    ...p,
    variants: (allVariants || []).filter(v => v.product_id === p.id),
  }));
}
---

<AdminLayout title="Products - SmartStore Admin">

  <!-- Page Heading -->
  <div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Products Management</h1>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addProductModal">
      <i class="bi bi-plus-lg me-1"></i> Add Product
    </button>
  </div>

  <!-- Search & Filter -->
  <div class="row mb-3">
    <div class="col-md-6">
      <input type="text" class="form-control" id="searchProduct" placeholder="Search products...">
    </div>
    <div class="col-md-3">
      <select class="form-select" id="filterCategory">
        <option value="">All Categories</option>
        <option value="Fashion">Fashion</option>
        <option value="Accessories">Accessories</option>
        <option value="Travel Gear">Travel Gear</option>
        <option value="Everyday Essentials">Everyday Essentials</option>
        <option value="Modern Menswear">Modern Menswear</option>
      </select>
    </div>
    <div class="col-md-3 text-end">
      <span class="text-muted" id="productCount">{productsWithVariants?.length || 0} products</span>
    </div>
  </div>

  <!-- Products Table -->
  <div class="card shadow mb-4">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-bordered" id="productsTable" width="100%" cellspacing="0">
          <thead>
            <tr>
              <th>Image</th>
              <th>Name / Variants</th>
              <th>SKU</th>
              <th>Category</th>
              <th>Price</th>
              <th>Stock</th>
              <th>Discount</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="productsBody">
            {productsWithVariants && productsWithVariants.length > 0 ? (
              productsWithVariants.map((product) => (
                <tr class="product-row" data-name={product.name.toLowerCase()} data-category={product.category || ''} data-id={product.id}>
                  <td>
                    <img 
                      src={product.image_url || '/assets/store/img/product/product-placeholder.webp'} 
                      alt={product.name} 
                      style="width: 50px; height: 50px; object-fit: cover; border-radius: 8px;"
                    />
                  </td>
                  <td>
                    <strong>{product.name}</strong>
                    <br />
                    <small class="text-muted">ID: {product.id?.slice(0, 8)}</small>
                    {product.variants && product.variants.length > 0 && (
                      <div class="mt-1">
                        {product.variants.map((v) => (
                          <span class="badge bg-info me-1" style="font-size: 10px;">
                            {v.name}: {v.value} (Stock: {v.stock})
                          </span>
                        ))}
                      </div>
                    )}
                  </td>
                  <td>
                    <span class="badge bg-secondary">SKU-{product.id?.slice(0, 6)}</span>
                  </td>
                  <td>{product.category || 'General'}</td>
                  <td>Rp {product.price.toLocaleString('id-ID')}</td>
                  <td>{product.stock || 0}</td>
                  <td>
                    {product.discount > 0 ? (
                      <span class="badge bg-warning">{product.discount}%</span>
                    ) : (
                      <span class="badge bg-light text-muted">0%</span>
                    )}
                  </td>
                  <td>
                    {product.is_active ? (
                      <span class="badge bg-success">Active</span>
                    ) : (
                      <span class="badge bg-danger">Inactive</span>
                    )}
                  </td>
                  <td>
                    <button class="btn btn-sm btn-outline-primary edit-btn" data-bs-toggle="modal" data-bs-target="#editProductModal" data-id={product.id}>
                      <i class="bi bi-pencil"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-success variant-btn" data-bs-toggle="modal" data-bs-target="#variantModal" data-id={product.id} data-name={product.name}>
                      <i class="bi bi-plus-circle"></i>
                    </button>
                    <button class="btn btn-sm btn-outline-danger delete-btn" data-id={product.id}>
                      <i class="bi bi-trash"></i>
                    </button>
                  </td>
                </tr>
              ))
            ) : (
              <tr>
                <td colspan="9" class="text-center py-4">No products found</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Add Product Modal -->
  <div class="modal fade" id="addProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-plus-lg me-2"></i>Add New Product</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="addProductForm">
          <div class="modal-body">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Product Name</label>
                <input type="text" class="form-control" id="addName" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" id="addCategory">
                  <option value="Fashion">Fashion</option>
                  <option value="Accessories">Accessories</option>
                  <option value="Travel Gear">Travel Gear</option>
                  <option value="Everyday Essentials">Everyday Essentials</option>
                  <option value="Modern Menswear">Modern Menswear</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Price (Rp)</label>
                <input type="number" class="form-control" id="addPrice" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Stock</label>
                <input type="number" class="form-control" id="addStock" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Discount (%)</label>
                <input type="number" class="form-control" id="addDiscount" value="0" min="0" max="100">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Status</label>
                <select class="form-select" id="addStatus">
                  <option value="true">Active</option>
                  <option value="false">Inactive</option>
                </select>
              </div>
              <div class="col-12 mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" id="addDescription" rows="3"></textarea>
              </div>
              <div class="col-12 mb-3">
                <label class="form-label">Image URL</label>
                <input type="text" class="form-control" id="addImage" placeholder="/assets/store/img/product/product-1.webp">
              </div>
            </div>
            <div id="addProductError" class="alert alert-danger d-none"></div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Save Product</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Edit Product Modal -->
  <div class="modal fade" id="editProductModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Product</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <form id="editProductForm">
          <input type="hidden" id="editId">
          <div class="modal-body">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Product Name</label>
                <input type="text" class="form-control" id="editName" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Category</label>
                <select class="form-select" id="editCategory">
                  <option value="Fashion">Fashion</option>
                  <option value="Accessories">Accessories</option>
                  <option value="Travel Gear">Travel Gear</option>
                  <option value="Everyday Essentials">Everyday Essentials</option>
                  <option value="Modern Menswear">Modern Menswear</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Price (Rp)</label>
                <input type="number" class="form-control" id="editPrice" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Stock</label>
                <input type="number" class="form-control" id="editStock" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Discount (%)</label>
                <input type="number" class="form-control" id="editDiscount" min="0" max="100">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Status</label>
                <select class="form-select" id="editStatus">
                  <option value="true">Active</option>
                  <option value="false">Inactive</option>
                </select>
              </div>
              <div class="col-12 mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" id="editDescription" rows="3"></textarea>
              </div>
              <div class="col-12 mb-3">
                <label class="form-label">Image URL</label>
                <input type="text" class="form-control" id="editImage">
              </div>
            </div>
            <div id="editProductError" class="alert alert-danger d-none"></div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary">Update Product</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ===== VARIAN MODAL ===== -->
  <div class="modal fade" id="variantModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Manage Variants</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" id="variantProductId">
          <h6 id="variantProductName" class="mb-3"></h6>
          
          <!-- Form Tambah Varian -->
          <div class="row g-2 mb-3 p-3 bg-light rounded">
            <div class="col-md-3">
              <select class="form-select form-select-sm" id="variantType">
                <option value="Color">Color</option>
                <option value="Size">Size</option>
                <option value="Other">Other</option>
              </select>
            </div>
            <div class="col-md-3">
              <input type="text" class="form-control form-select-sm" id="variantValue" placeholder="Value (e.g. Red, L)">
            </div>
            <div class="col-md-2">
              <input type="number" class="form-control form-select-sm" id="variantStock" placeholder="Stock" value="0">
            </div>
            <div class="col-md-2">
              <input type="number" class="form-control form-select-sm" id="variantPriceExtra" placeholder="Extra Price" value="0">
            </div>
            <div class="col-md-2">
              <button class="btn btn-sm btn-primary w-100" id="addVariantBtn">Add</button>
            </div>
          </div>

          <!-- Daftar Varian -->
          <div id="variantList" class="mt-2">
            <p class="text-muted text-center">Loading variants...</p>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    //@ts-nocheck
    import { supabaseAdmin as supabase } from "@/lib/supabase/client";

    // Filter products
    document.getElementById('searchProduct')?.addEventListener('keyup', function() {
      const search = this.value.toLowerCase();
      const category = document.getElementById('filterCategory').value;
      const rows = document.querySelectorAll('.product-row');
      let count = 0;

      rows.forEach(row => {
        const name = row.dataset.name || '';
        const cat = row.dataset.category || '';
        const match = name.includes(search) && (category === '' || cat === category);
        row.style.display = match ? '' : 'none';
        if (match) count++;
      });

      document.getElementById('productCount').textContent = count + ' products';
    });

    document.getElementById('filterCategory')?.addEventListener('change', function() {
      const search = document.getElementById('searchProduct').value.toLowerCase();
      const category = this.value;
      const rows = document.querySelectorAll('.product-row');
      let count = 0;

      rows.forEach(row => {
        const name = row.dataset.name || '';
        const cat = row.dataset.category || '';
        const match = name.includes(search) && (category === '' || cat === category);
        row.style.display = match ? '' : 'none';
        if (match) count++;
      });

      document.getElementById('productCount').textContent = count + ' products';
    });

    // ============= EDIT PRODUCT =============
    document.querySelectorAll('.edit-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const id = this.dataset.id;
        
        const { data: product } = await supabase
          .from('products')
          .select('*')
          .eq('id', id)
          .single();

        if (product) {
          document.getElementById('editId').value = product.id;
          document.getElementById('editName').value = product.name;
          document.getElementById('editCategory').value = product.category || '';
          document.getElementById('editPrice').value = product.price;
          document.getElementById('editStock').value = product.stock || 0;
          document.getElementById('editDiscount').value = product.discount || 0;
          document.getElementById('editStatus').value = String(product.is_active);
          document.getElementById('editDescription').value = product.description || '';
          document.getElementById('editImage').value = product.image_url || '';
        }
      });
    });

    // ============= DELETE PRODUCT =============
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async function() {
        const id = this.dataset.id;
        if (!confirm('Are you sure you want to delete this product?')) return;

        const { error } = await supabase
          .from('products')
          .delete()
          .eq('id', id);

        if (error) {
          alert('Error: ' + error.message);
          return;
        }

        window.location.reload();
      });
    });

    // ============= VARIAN MODAL =============
    let currentProductId = null;

    document.querySelectorAll('.variant-btn').forEach(btn => {
      btn.addEventListener('click', function() {
        currentProductId = this.dataset.id;
        const productName = this.dataset.name;
        document.getElementById('variantProductId').value = currentProductId;
        document.getElementById('variantProductName').textContent = 'Product: ' + productName;
        loadVariants(currentProductId);
      });
    });

    async function loadVariants(productId) {
      const list = document.getElementById('variantList');
      list.innerHTML = '<p class="text-muted text-center">Loading variants...</p>';

      const { data: variants } = await supabase
        .from('product_variants')
        .select('*')
        .eq('product_id', productId);

      if (!variants || variants.length === 0) {
        list.innerHTML = '<p class="text-muted text-center">No variants yet.</p>';
        return;
      }

      list.innerHTML = `
        <table class="table table-sm table-bordered">
          <thead>
            <tr>
              <th>Name</th>
              <th>Value</th>
              <th>Stock</th>
              <th>Extra Price</th>
              <th>Action</th>
            </tr>
          </thead>
          <tbody>
            ${variants.map(v => `
              <tr>
                <td>${v.name}</td>
                <td>${v.value}</td>
                <td>${v.stock || 0}</td>
                <td>Rp ${(v.price_extra || 0).toLocaleString('id-ID')}</td>
                <td>
                  <button class="btn btn-sm btn-outline-danger delete-variant-btn" data-id="${v.id}">
                    <i class="bi bi-trash"></i>
                  </button>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      `;

      // Delete variant
      document.querySelectorAll('.delete-variant-btn').forEach(btn => {
        btn.addEventListener('click', async function() {
          const id = this.dataset.id;
          if (!confirm('Delete this variant?')) return;
          
          const { error } = await supabase
            .from('product_variants')
            .delete()
            .eq('id', id);
          
          if (!error) loadVariants(currentProductId);
        });
      });
    }

    // Add variant
    document.getElementById('addVariantBtn')?.addEventListener('click', async function() {
      const productId = document.getElementById('variantProductId').value;
      const name = document.getElementById('variantType').value;
      const value = document.getElementById('variantValue').value.trim();
      const stock = parseInt(document.getElementById('variantStock').value) || 0;
      const price_extra = parseFloat(document.getElementById('variantPriceExtra').value) || 0;

      if (!value) {
        alert('Please enter a value!');
        return;
      }

      const { error } = await supabase
        .from('product_variants')
        .insert({
          product_id: productId,
          name: name,
          value: value,
          stock: stock,
          price_extra: price_extra
        });

      if (error) {
        alert('Error: ' + error.message);
      } else {
        document.getElementById('variantValue').value = '';
        document.getElementById('variantStock').value = '0';
        document.getElementById('variantPriceExtra').value = '0';
        loadVariants(productId);
      }
    });

    // Add Product
    document.getElementById('addProductForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById('addProductError');
      if (errorEl) {
        errorEl.classList.add('d-none');
        errorEl.textContent = '';
      }

      const name = document.getElementById('addName').value;
      const slug = name.toLowerCase().replace(/ /g, '-');
      const category = document.getElementById('addCategory').value;
      const price = parseFloat(document.getElementById('addPrice').value);
      const stock = parseInt(document.getElementById('addStock').value);
      const discount = parseFloat(document.getElementById('addDiscount').value) || 0;
      const is_active = document.getElementById('addStatus').value === 'true';
      const description = document.getElementById('addDescription').value;
      const image_url = document.getElementById('addImage').value || '/assets/store/img/product/product-placeholder.webp';

      const { data, error } = await supabase
        .from('products')
        .insert({
          name,
          slug,
          category,
          price,
          stock,
          discount,
          is_active,
          description,
          image_url
        });

      if (error) {
        if (errorEl) {
          errorEl.textContent = error.message;
          errorEl.classList.remove('d-none');
        }
        return;
      }

      window.location.reload();
    });

    // Update Product
    document.getElementById('editProductForm')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const errorEl = document.getElementById('editProductError');
      if (errorEl) {
        errorEl.classList.add('d-none');
        errorEl.textContent = '';
      }

      const id = document.getElementById('editId').value;
      const name = document.getElementById('editName').value;
      const slug = name.toLowerCase().replace(/ /g, '-');
      const category = document.getElementById('editCategory').value;
      const price = parseFloat(document.getElementById('editPrice').value);
      const stock = parseInt(document.getElementById('editStock').value);
      const discount = parseFloat(document.getElementById('editDiscount').value) || 0;
      const is_active = document.getElementById('editStatus').value === 'true';
      const description = document.getElementById('editDescription').value;
      const image_url = document.getElementById('editImage').value || '/assets/store/img/product/product-placeholder.webp';

      const { error } = await supabase
        .from('products')
        .update({
          name,
          slug,
          category,
          price,
          stock,
          discount,
          is_active,
          description,
          image_url
        })
        .eq('id', id);

      if (error) {
        if (errorEl) {
          errorEl.textContent = error.message;
          errorEl.classList.remove('d-none');
        }
        return;
      }

      window.location.reload();
    });
  </script>
</AdminLayout>