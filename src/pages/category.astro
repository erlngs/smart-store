                        <span class="item-cost">$139.00</span>
                        <button type="button" class="cart-icon-btn" aria-label="Add to cart">
                          <i class="bi bi-cart3"></i>
                        </button>
                      </div>
                    </div>
                  </article>
                </div><!-- End Product Item -->

                <!-- Product 2 -->
                <div class="col-6 col-lg-4" data-aos="fade-up" data-aos-delay="150">
                  <article class="item-card">
                    <div class="item-media">
                      <img src="assets/store/img/product/product-m-9.webp" class="primary-img img-fluid" alt="Product" loading="lazy">
                      <img src="assets/store/img/product/product-m-10.webp" class="secondary-img img-fluid" alt="Product Alternate" loading="lazy">
                      <button type="button" class="wishlist-toggle" aria-label="Add to wishlist">
                        <i class="bi bi-heart"></i>
                      </button>
                      <span class="item-label label-new">New In</span>
                      <div class="quick-add">
                        <button type="button" class="quick-add-btn">
                          <i class="bi bi-bag-plus me-1"></i> Quick Add
                        </button>
                      </div>
                    </div>
