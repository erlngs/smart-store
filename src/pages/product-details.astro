<BaseLayout title={`${product.name} - SmartStore`} bodyClass="product-details">

  <!-- Product Details Section -->
  <section id="product-details" class="product-details section">
    <div class="container" data-aos="fade-up" data-aos-delay="100">
      <div class="row g-5 align-items-start">

        <!-- Product Gallery -->
        <div class="col-lg-6" data-aos="fade-right" data-aos-delay="150">
          <div class="gallery-wrapper">
            <div class="gallery-thumbs">
              <div class="thumb-item thumbnail-item active" data-image={product.image_url || '/assets/store/img/product/product-placeholder.webp'}>
