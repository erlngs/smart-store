---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="product-details - SmartStore" bodyClass="product-details">


    <!-- Product Details Section -->
    <section id="product-details" class="product-details section">

      <div class="container" data-aos="fade-up" data-aos-delay="100">

        <div class="row g-5 align-items-start">
          <!-- Product Gallery -->
          <div class="col-lg-6" data-aos="fade-right" data-aos-delay="150">
            <div class="gallery-wrapper">
              <div class="gallery-thumbs">
                <div class="thumb-item thumbnail-item active" data-image="assets/store/img/product/product-details-3.webp">
                  <img src="assets/store/img/product/product-details-3.webp" alt="Angle 1" class="img-fluid">
                </div>
                <div class="thumb-item thumbnail-item" data-image="assets/store/img/product/product-details-4.webp">
                  <img src="assets/store/img/product/product-details-4.webp" alt="Angle 2" class="img-fluid">
                </div>
                <div class="thumb-item thumbnail-item" data-image="assets/store/img/product/product-details-5.webp">
                  <img src="assets/store/img/product/product-details-5.webp" alt="Angle 3" class="img-fluid">
                </div>
                <div class="thumb-item thumbnail-item" data-image="assets/store/img/product/product-details-6.webp">
                  <img src="assets/store/img/product/product-details-6.webp" alt="Angle 4" class="img-fluid">
                </div>
                <div class="thumb-item thumbnail-item" data-image="assets/store/img/product/product-details-7.webp">
                  <img src="assets/store/img/product/product-details-7.webp" alt="Angle 5" class="img-fluid">
                </div>
              </div><!-- End Gallery Thumbs -->

              <div class="gallery-main">
                <div class="main-image-container">
                  <span class="sale-tag">-21%</span>
                  <img id="main-product-image" src="assets/store/img/product/product-details-3.webp" data-zoom="assets/store/img/product/product-details-3.webp" alt="Product" class="img-fluid drift-zoom">
                  <div class="image-zoom-container"></div>
                  <button class="image-nav-btn prev-image" type="button"><i class="bi bi-chevron-left"></i></button>
                  <button class="image-nav-btn next-image" type="button"><i class="bi bi-chevron-right"></i></button>
                </div>
              </div><!-- End Gallery Main -->
            </div>
          </div><!-- End Product Gallery -->

          <!-- Product Info -->
          <div class="col-lg-6" data-aos="fade-left" data-aos-delay="200">
            <div class="product-info">
              <span class="category-tag">Sound Equipment</span>

              <h1 class="item-title">Vivamus sagittis lacus vel augue laoreet rutrum faucibus dolor</h1>

              <div class="rating-row">
                <div class="star-group">
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-fill"></i>
                  <i class="bi bi-star-half"></i>
                </div>
                <span class="rating-label">4.6</span>
                <a href="#" class="review-link">(143 ratings)</a>
              </div>

              <div class="price-block">
                <span class="current-price">$189.99</span>
                <span class="original-price">$239.99</span>
                <span class="savings-pill">Save $50.00</span>
              </div>

              <div class="description-text">
                <p>Quis autem vel eum iure reprehenderit qui in ea voluptate velit esse quam nihil molestiae consequatur, vel illum qui dolorem eum fugiat quo voluptas nulla pariatur.</p>
              </div>

              <div class="availability-row">
                <span class="in-stock"><i class="bi bi-patch-check-fill"></i> In Stock</span>
                <span class="remaining">Only 18 remaining</span>
              </div>

              <div class="color-options">
                <span class="option-label">Select Color:</span>
                <div class="swatches">
                  <div class="swatch active" data-color="Obsidian" style="background: #1a1a2e;">
                    <i class="bi bi-check2"></i>
                  </div>
                  <div class="swatch" data-color="Ivory" style="background: #f0ece2;">
                    <i class="bi bi-check2"></i>
                  </div>
                  <div class="swatch" data-color="Sapphire" style="background: #0055aa;">
                    <i class="bi bi-check2"></i>
                  </div>
                  <div class="swatch" data-color="Moss" style="background: #2d6a4f;">
                    <i class="bi bi-check2"></i>
                  </div>
                </div>
                <span class="chosen-color">Obsidian</span>
              </div>

              <div class="purchase-controls">
                <div class="qty-group">
                  <div class="quantity-selector">
                    <button class="quantity-btn decrease" type="button"><i class="bi bi-dash"></i></button>
                    <input type="number" class="quantity-input" value="1" min="1" max="18">
                    <button class="quantity-btn increase" type="button"><i class="bi bi-plus"></i></button>
                  </div>
                </div>
                <button class="btn add-cart-btn">
                  <i class="bi bi-bag-plus"></i> Add to Cart
                </button>
                <button class="btn fav-btn" title="Save to Wishlist">
                  <i class="bi bi-heart"></i>
                </button>
              </div>

              <button class="btn instant-buy-btn">
                <i class="bi bi-lightning-charge"></i> Purchase Instantly
              </button>

              <div class="perks-grid">
                <div class="perk-card">
                  <i class="bi bi-truck"></i>
                  <span>Free shipping $75+</span>
                </div>
                <div class="perk-card">
                  <i class="bi bi-arrow-counterclockwise"></i>
                  <span>45-day returns</span>
                </div>
                <div class="perk-card">
                  <i class="bi bi-shield-check"></i>
                  <span>3-year warranty</span>
                </div>
                <div class="perk-card">
                  <i class="bi bi-headset"></i>
                  <span>24/7 support</span>
                </div>
              </div><!-- End Perks Grid -->
            </div>
          </div><!-- End Product Info -->
        </div>

        <!-- Product Detail Tabs -->
        <div class="row mt-5" data-aos="fade-up" data-aos-delay="300">
          <div class="col-12">
            <div class="detail-tabs">
              <ul class="tab-links nav" role="tablist">
                <li><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#product-details-tab-desc" type="button">Description</button></li>
                <li><button class="nav-link" data-bs-toggle="tab" data-bs-target="#product-details-tab-specs" type="button">Specifications</button></li>
                <li><button class="nav-link" data-bs-toggle="tab" data-bs-target="#product-details-tab-feedback" type="button">Feedback (143)</button></li>
              </ul>

              <div class="tab-content">
                <!-- Description Tab -->
                <div class="tab-pane fade show active" id="product-details-tab-desc">
                  <div class="desc-body">
                    <div class="row g-4">
                      <div class="col-lg-7">
                        <div class="desc-main">
                          <h3>About This Product</h3>
                          <p>Temporibus autem quibusdam et aut officiis debitis aut rerum necessitatibus saepe eveniet ut et voluptates repudiandae sint et molestiae non recusandae. Itaque earum rerum hic tenetur a sapiente delectus, ut aut reiciendis voluptatibus maiores.</p>

                          <h4>Feature Highlights</h4>
                          <div class="row g-3">
                            <div class="col-sm-6">
                              <div class="feature-item">
                                <i class="bi bi-soundwave"></i>
                                <div>
                                  <h5>Premium Sound</h5>
                                  <p>Temporibus autem quibusdam officiis debitis rerum</p>
                                </div>
                              </div>
                            </div>
                            <div class="col-sm-6">
                              <div class="feature-item">
                                <i class="bi bi-battery-full"></i>
                                <div>
                                  <h5>Extended Battery</h5>
                                  <p>Saepe eveniet ut et voluptates repudiandae sint</p>
                                </div>
                              </div>
                            </div>
                            <div class="col-sm-6">
                              <div class="feature-item">
                                <i class="bi bi-bluetooth"></i>
                                <div>
                                  <h5>Seamless Pairing</h5>
                                  <p>Itaque earum rerum hic tenetur sapiente delectus</p>
                                </div>
                              </div>
                            </div>
                            <div class="col-sm-6">
                              <div class="feature-item">
                                <i class="bi bi-gem"></i>
                                <div>
                                  <h5>Ergonomic Design</h5>
                                  <p>Aut reiciendis voluptatibus maiores alias consequatur</p>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <div class="col-lg-5">
                        <div class="box-contents">
                          <h4><i class="bi bi-box-seam"></i> What's Included</h4>
                          <ul>
                            <li><i class="bi bi-check2-circle"></i> Premium Audio Device</li>
                            <li><i class="bi bi-check2-circle"></i> Protective Travel Case</li>
                            <li><i class="bi bi-check2-circle"></i> USB-C Charging Cable</li>
                            <li><i class="bi bi-check2-circle"></i> 3.5mm AUX Connector</li>
                            <li><i class="bi bi-check2-circle"></i> Setup Manual</li>
                            <li><i class="bi bi-check2-circle"></i> Warranty Certificate</li>
                          </ul>
                        </div>
                      </div>
                    </div>
                  </div>
                </div><!-- End Description Tab -->

                <!-- Specifications Tab -->
                <div class="tab-pane fade" id="product-details-tab-specs">
                  <div class="specs-body">
                    <div class="row g-4">
                      <div class="col-md-6">
                        <div class="spec-group">
                          <h4>Audio Performance</h4>
                          <table class="spec-table">
                            <tbody>
                              <tr>
                                <td>Frequency Range</td>
                                <td>15Hz - 25kHz</td>
                              </tr>
                              <tr>
                                <td>Driver Size</td>
                                <td>50mm Dynamic</td>
                              </tr>
                              <tr>
                                <td>Sensitivity</td>
                                <td>98dB SPL</td>
                              </tr>
                              <tr>
                                <td>Impedance</td>
                                <td>24 Ohm</td>
                              </tr>
                              <tr>
                                <td>THD</td>
                                <td>&lt; 0.5%</td>
                              </tr>
                            </tbody>
                          </table>
                        </div>
                      </div>

                      <div class="col-md-6">
                        <div class="spec-group">
                          <h4>Wireless &amp; Power</h4>
                          <table class="spec-table">
                            <tbody>
                              <tr>
                                <td>Protocol</td>
                                <td>Bluetooth 5.3</td>
                              </tr>
                              <tr>
                                <td>Range</td>
                                <td>Up to 30ft (10m)</td>
                              </tr>
                              <tr>
                                <td>Battery</td>
                                <td>800mAh Li-ion</td>
                              </tr>
                              <tr>
                                <td>Playtime</td>
                                <td>35+ hours</td>
                              </tr>
                              <tr>
                                <td>Charge Time</td>
                                <td>2.5 hours</td>
                              </tr>
                            </tbody>
                          </table>
                        </div>
                      </div>

                      <div class="col-md-6">
                        <div class="spec-group">
                          <h4>Build &amp; Dimensions</h4>
                          <table class="spec-table">
                            <tbody>
                              <tr>
                                <td>Weight</td>
                                <td>285g</td>
                              </tr>
                              <tr>
                                <td>Dimensions</td>
                                <td>190 x 165 x 82mm</td>
                              </tr>
                              <tr>
                                <td>Cushion Material</td>
                                <td>Memory Foam</td>
                              </tr>
                              <tr>
                                <td>Frame</td>
                                <td>Adjustable Steel</td>
                              </tr>
                            </tbody>
                          </table>
                        </div>
                      </div>

                      <div class="col-md-6">
                        <div class="spec-group">
                          <h4>Smart Features</h4>
                          <table class="spec-table">
                            <tbody>
                              <tr>
                                <td>Noise Cancelling</td>
                                <td>Hybrid ANC</td>
                              </tr>
                              <tr>
                                <td>Voice Assistant</td>
                                <td>Siri &amp; Google</td>
                              </tr>
                              <tr>
                                <td>Microphone</td>
                                <td>Dual Array</td>
                              </tr>
                              <tr>
                                <td>Water Resistance</td>
                                <td>IPX5</td>
                              </tr>
                            </tbody>
                          </table>
                        </div>
                      </div>
                    </div>
                  </div>
                </div><!-- End Specifications Tab -->

                <!-- Feedback Tab -->
                <div class="tab-pane fade" id="product-details-tab-feedback">
                  <div class="feedback-body">
                    <div class="row g-4 mb-4">
                      <div class="col-md-4">
                        <div class="score-summary">
                          <div class="big-score">4.6</div>
                          <div class="score-stars">
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-fill"></i>
                            <i class="bi bi-star-half"></i>
                          </div>
                          <div class="total-count">Based on 143 ratings</div>
                          <button class="btn write-review-btn">Write a Review</button>
                        </div>
                      </div>

                      <div class="col-md-8">
                        <div class="bars-breakdown">
                          <div class="bar-row">
                            <span class="bar-label">5 <i class="bi bi-star-fill"></i></span>
                            <div class="bar-track">
                              <div class="bar-fill" style="width: 68%;"></div>
                            </div>
                            <span class="bar-count">97</span>
                          </div>
                          <div class="bar-row">
                            <span class="bar-label">4 <i class="bi bi-star-fill"></i></span>
                            <div class="bar-track">
                              <div class="bar-fill" style="width: 22%;"></div>
                            </div>
                            <span class="bar-count">31</span>
                          </div>
                          <div class="bar-row">
                            <span class="bar-label">3 <i class="bi bi-star-fill"></i></span>
                            <div class="bar-track">
                              <div class="bar-fill" style="width: 6%;"></div>
                            </div>
                            <span class="bar-count">9</span>
                          </div>
                          <div class="bar-row">
                            <span class="bar-label">2 <i class="bi bi-star-fill"></i></span>
                            <div class="bar-track">
                              <div class="bar-fill" style="width: 3%;"></div>
                            </div>
                            <span class="bar-count">4</span>
                          </div>
                          <div class="bar-row">
                            <span class="bar-label">1 <i class="bi bi-star-fill"></i></span>
                            <div class="bar-track">
                              <div class="bar-fill" style="width: 1%;"></div>
                            </div>
                            <span class="bar-count">2</span>
                          </div>
                        </div>
                      </div>
                    </div><!-- End Rating Summary -->

                    <div class="feedback-list">
                      <article class="feedback-card">
                        <div class="feedback-header">
                          <img src="assets/store/img/person/person-m-8.webp" alt="Reviewer" class="reviewer-avatar">
                          <div class="reviewer-info">
                            <strong>Marcus Bennett</strong>
                            <div class="review-meta">
                              <span class="stars">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                              </span>
                              <span class="date">April 12, 2024</span>
                            </div>
                          </div>
                        </div>
                        <h5>Exceptional clarity and comfortable wear</h5>
                        <p>At vero eos et accusamus et iusto odio dignissimos ducimus qui blanditiis praesentium voluptatum deleniti atque corrupti quos dolores et quas molestias excepturi sint occaecati.</p>
                        <div class="feedback-footer">
                          <button class="helpful-btn"><i class="bi bi-hand-thumbs-up"></i> Helpful (14)</button>
                          <button class="reply-btn"><i class="bi bi-reply"></i> Reply</button>
                        </div>
                      </article><!-- End Feedback Card -->

                      <article class="feedback-card">
                        <div class="feedback-header">
                          <img src="assets/store/img/person/person-f-11.webp" alt="Reviewer" class="reviewer-avatar">
                          <div class="reviewer-info">
                            <strong>Olivia Torres</strong>
                            <div class="review-meta">
                              <span class="stars">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star"></i>
                              </span>
                              <span class="date">March 5, 2024</span>
                            </div>
                          </div>
                        </div>
                        <h5>Solid performance with minor quirks</h5>
                        <p>Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam eaque ipsa quae ab illo inventore veritatis. Generally pleased with my purchase.</p>
                        <div class="feedback-footer">
                          <button class="helpful-btn"><i class="bi bi-hand-thumbs-up"></i> Helpful (9)</button>
                          <button class="reply-btn"><i class="bi bi-reply"></i> Reply</button>
                        </div>
                      </article><!-- End Feedback Card -->

                      <article class="feedback-card">
                        <div class="feedback-header">
                          <img src="assets/store/img/person/person-m-12.webp" alt="Reviewer" class="reviewer-avatar">
                          <div class="reviewer-info">
                            <strong>Jason Kimura</strong>
                            <div class="review-meta">
                              <span class="stars">
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                                <i class="bi bi-star-fill"></i>
                              </span>
                              <span class="date">January 18, 2024</span>
                            </div>
                          </div>
                        </div>
                        <h5>Ideal companion for remote professionals</h5>
                        <p>Nemo enim ipsam voluptatem quia voluptas sit aspernatur aut odit aut fugit, sed quia consequuntur magni dolores eos qui ratione voluptatem sequi nesciunt neque porro quisquam est.</p>
                        <div class="feedback-footer">
                          <button class="helpful-btn"><i class="bi bi-hand-thumbs-up"></i> Helpful (18)</button>
                          <button class="reply-btn"><i class="bi bi-reply"></i> Reply</button>
                        </div>
                      </article><!-- End Feedback Card -->

                      <div class="more-reviews-wrap">
                        <button class="btn load-more-btn">Load More Reviews</button>
                      </div>
                    </div><!-- End Feedback List -->
                  </div>
                </div><!-- End Feedback Tab -->
              </div>
            </div>
          </div>
        </div>

      </div>

    </section><!-- /Product Details Section -->

</BaseLayout>