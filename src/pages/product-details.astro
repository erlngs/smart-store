      <!-- Product Detail Tabs -->
      <div class="row mt-5" data-aos="fade-up" data-aos-delay="300">
        <div class="col-12">
          <div class="detail-tabs">
            <ul class="tab-links nav" role="tablist">
              <li><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#product-details-tab-desc" type="button">Description</button></li>
              <li><button class="nav-link" data-bs-toggle="tab" data-bs-target="#product-details-tab-specs" type="button">Specifications</button></li>
              <li><button class="nav-link" data-bs-toggle="tab" data-bs-target="#product-details-tab-feedback" type="button">Feedback ({totalReviews})</button></li>
            </ul>

            <div class="tab-content">
              <!-- Description Tab -->
              <div class="tab-pane fade show active" id="product-details-tab-desc">
                <div class="desc-body">
                  <div class="row g-4">
                    <div class="col-lg-7">
                      <div class="desc-main">
                        <h3>About This Product</h3>
                        <p>{product.description || 'Deskripsi produk belum tersedia.'}</p>
                        {variants && variants.length > 0 && (
                          <>
                            <h4>Available Variants</h4>
                            <div class="row g-3">
