});

    // Submit Review
    document.getElementById('submitReviewBtn')?.addEventListener('click', async function() {
      const errorEl = document.getElementById('reviewError');
      const successEl = document.getElementById('reviewSuccess');
      errorEl.classList.add('d-none');
      successEl.classList.add('d-none');

      const productId = document.getElementById('reviewProductId').value;
      const rating = parseInt(document.getElementById('reviewRating').value);
      const comment = document.getElementById('reviewComment').value.trim();

      if (rating === 0) {
        errorEl.textContent = 'Silakan pilih rating terlebih dahulu!';
        errorEl.classList.remove('d-none');
        return;
      }

      if (!comment) {
        errorEl.textContent = 'Silakan tulis ulasan terlebih dahulu!';
        errorEl.classList.remove('d-none');
        return;
      }

      const { data: { session } } = await supabase.auth.getSession();
      if (!session) {
        window.location.href = '/login';
        return;
      }

      // Cek apakah user sudah pernah review produk ini
      const { data: existing } = await supabase
        .from('reviews')
        .select('id')
        .eq('user_id', session.user.id)
        .eq('product_id', productId)
        .maybeSingle();

      if (existing) {
        errorEl.textContent = 'Anda sudah pernah mereview produk ini!';
        errorEl.classList.remove('d-none');
        return;
      }

      // Cek apakah user pernah membeli produk ini
      const { data: orders } = await supabase
        .from('orders')
        .select('id')
        .eq('user_id', session.user.id)
        .in('status', ['delivered', 'paid', 'shipped']);

      if (!orders || orders.length === 0) {
        errorEl.textContent = 'Anda harus membeli produk ini terlebih dahulu untuk memberi review!';
        errorEl.classList.remove('d-none');
        return;
      }

      // Submit review
      const { error } = await supabase
        .from('reviews')
        .insert({
          user_id: session.user.id,
          product_id: productId,
          rating: rating,
          comment: comment
        });

      if (error) {
        errorEl.textContent = 'Gagal mengirim review: ' + error.message;
        errorEl.classList.remove('d-none');
      } else {
        successEl.textContent = 'Review berhasil dikirim!';
        successEl.classList.remove('d-none');
        
        // Reset form
        document.getElementById('reviewRating').value = 0;
        document.getElementById('reviewComment').value = '';
        document.querySelectorAll('#ratingStars .bi').forEach(star => {
          star.className = 'bi bi-star';
          star.style.color = '#ddd';
        });
        selectedRating = 0;
        document.getElementById('ratingLabel').textContent = 'Klik bintang untuk memberi rating';

        setTimeout(() => {
          const modal = bootstrap.Modal.getInstance(document.getElementById('writeReviewModal'));
          modal.hide();
          window.location.reload();
        }, 1500);
      }
    });
