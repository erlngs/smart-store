---
const currentPath = Astro.url.pathname;
---

<header id="header" class="header position-relative">
    <!-- Header Bar -->
    <div class="header-bar">
      <div class="container-fluid container-xl">
        <div class="d-flex align-items-center justify-content-between">

          <!-- Logo -->
          <a href="/" class="logo d-flex align-items-center">
            <h1 class="sitename">SmartStore</h1>
          </a>

          <!-- Search -->
          <form class="header-search d-none d-lg-flex">
            <input type="text" class="search-input" placeholder="Search products, categories, brands...">
            <button class="search-btn" type="submit">
              <i class="bi bi-search"></i>
              <span class="d-none d-xl-inline">Search</span>
            </button>
          </form>

          <!-- Quick Links -->
          <div class="quick-links d-none d-xl-flex align-items-center">
            <a href="#" class="quick-link">
              <i class="bi bi-geo-alt"></i>
              <span>Stores</span>
            </a>
            <a href="#" class="quick-link">
              <i class="bi bi-question-circle"></i>
              <span>Help</span>
            </a>
          </div>

          <!-- Header Actions -->
          <div class="header-actions d-flex align-items-center">

            <!-- Mobile Search Toggle -->
            <button class="action-icon mobile-search-toggle d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mobileSearch" aria-expanded="false" aria-controls="mobileSearch">
              <i class="bi bi-search"></i>
            </button>

            <!-- Account -->
            <div class="dropdown account-dropdown">
              <button class="action-icon" data-bs-toggle="dropdown" aria-label="Account">
                <i class="bi bi-person"></i>
                <span class="action-label d-none d-md-inline">Account</span>
              </button>
              <div class="dropdown-menu account-panel">

                <!-- Versi LOGGED OUT (default tampil) -->
                <div id="accountPanelGuest">
                  <div class="account-panel-header">
                    <h6>Welcome!</h6>
                    <p>Sign in for the best experience</p>
                  </div>
                  <div class="account-panel-auth">
                    <a href="/login" class="btn btn-signin">Sign In</a>
                    <a href="/register" class="btn btn-register">Create Account</a>
                  </div>
                  <div class="account-panel-links">
                    <a href="#">
                      <i class="bi bi-box-seam"></i>
                      <span>My Orders</span>
                    </a>
                    <a href="#">
                      <i class="bi bi-arrow-return-left"></i>
                      <span>Returns &amp; Refunds</span>
                    </a>
                    <a href="#">
                      <i class="bi bi-question-circle"></i>
                      <span>Help Center</span>
                    </a>
                  </div>
                </div>

                <!-- Versi LOGGED IN (disembunyikan default, ditampilkan lewat JS) -->
                <div id="accountPanelUser" style="display: none;">
                  <div class="account-panel-header">
                    <h6 id="accountUserName">Welcome, User!</h6>
                    <p id="accountUserEmail"></p>
                  </div>
                  <div class="account-panel-links">
                    <a href="/account">
                      <i class="bi bi-person"></i>
                      <span>My Account</span>
                    </a>
                    <a href="/account#orders">
                      <i class="bi bi-box-seam"></i>
                      <span>My Orders</span>
                    </a>
                   <a href="/wishlist">
  <i class="bi bi-heart"></i>
  <span>Wishlist <span id="wishlistCount" style="background: #dc3545; color: white; border-radius: 50%; padding: 0 6px; font-size: 10px; margin-left: 4px;">0</span></span>
</a>
                  </div>
                  <div class="account-panel-auth">
                    <button id="logoutBtnHeader" class="btn btn-danger w-100">Logout</button>
                  </div>
                </div>

              </div>
            </div>

            <!-- Cart -->
            <div class="dropdown cart-dropdown">
              <button class="action-icon" data-bs-toggle="dropdown" aria-label="Cart">
                <i class="bi bi-cart3"></i>
                <span class="action-label d-none d-md-inline">Cart</span>
                <span class="count-dot" id="cartCountBadge" style="display: none;">0</span>
              </button>
              <div class="dropdown-menu cart-panel" id="cartPanel">
                <div class="cart-panel-header">
                  <h6>Shopping Cart</h6>
                  <span class="item-count" id="cartItemCount">0 items</span>
                </div>
                <div class="cart-panel-body" id="cartItems">
                  <div id="cartItemsList"></div>
                </div>
                <div class="cart-panel-footer">
                  <div class="cart-subtotal">
                    <span>Subtotal</span>
                    <span class="cart-subtotal-price" id="cartSubtotal">Rp 0</span>
                  </div>
                  <a href="/checkout" class="btn btn-checkout">Checkout</a>
                  <a href="/cart" class="btn-viewcart">View full cart →</a>
                </div>
              </div>
            </div>

            <!-- Mobile Navigation Toggle -->
            <i class="mobile-nav-toggle d-xl-none bi bi-list me-0"></i>

          </div>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="header-nav">
      <div class="container-fluid container-xl position-relative">
        <nav id="navmenu" class="navmenu">
          <ul>
            <li><a href="/" class:list={{ active: currentPath === "/" }}>Home</a></li>
            <li><a href="/about" class:list={{ active: currentPath === "/about" }}>About</a></li>
            <li><a href="/category" class:list={{ active: currentPath === "/category" }}>Category</a></li>
            <li><a href="/artikel" class:list={{ active: currentPath.startsWith("/artikel") }}>Artikel</a></li>
            
            <!-- Products Dropdown -->
            <li class="dropdown">
              <a href="#"><span>Products</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
              <ul id="productDropdown">
                <li><a href="/category">All Products</a></li>
                <li><hr class="dropdown-divider"></li>
                <li class="text-muted small px-3 py-1" id="loadingProducts">Loading products...</li>
              </ul>
            </li>

            <li><a href="/cart" class:list={{ active: currentPath === "/cart" }}>Cart</a></li>
            <li><a href="/checkout" class:list={{ active: currentPath === "/checkout" }}>Checkout</a></li>
            <li><a href="/account?tab=track" class:list={{ active: currentPath === "/account" }}>Track Order</a></li>
          </ul>
        </nav>
      </div>
    </div>
                
    <!-- Mobile Search Form -->
    <div class="collapse" id="mobileSearch">
      <div class="container-fluid container-xl">
        <form class="mobile-search-form">
          <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control" placeholder="Search products...">
          </div>
        </form>
      </div>
    </div>

  </header>

<script>
  //@ts-nocheck
  import { supabase } from "@/lib/supabase/client";

  // ============= CEK STATUS LOGIN (client-side) =============
  async function checkAuthStatus() {
    const { data: { session } } = await supabase.auth.getSession();
    const guestPanel = document.getElementById('accountPanelGuest');
    const userPanel = document.getElementById('accountPanelUser');

    if (session) {
      guestPanel.style.display = 'none';
      userPanel.style.display = 'block';

      const { data: profile } = await supabase
        .from('profiles')
        .select('full_name')
        .eq('id', session.user.id)
        .single();

      const nameEl = document.getElementById('accountUserName');
      const emailEl = document.getElementById('accountUserEmail');
      if (nameEl) nameEl.textContent = `Welcome, ${profile?.full_name || 'User'}!`;
      if (emailEl) emailEl.textContent = session.user.email || '';

      // Load wishlist count
      loadWishlistCount();
    } else {
      guestPanel.style.display = 'block';
      userPanel.style.display = 'none';
    }
  }

  // ============= FUNGSI LOAD WISHLIST COUNT =============
  async function loadWishlistCount() {
    const { data: { session } } = await supabase.auth.getSession();
    const wishlistCountEl = document.getElementById('wishlistCount');
    
    if (!session || !wishlistCountEl) return;

    const { count, error } = await supabase
      .from('wishlists')
      .select('*', { count: 'exact', head: true })
      .eq('user_id', session.user.id);

    if (!error) {
      wishlistCountEl.textContent = count || 0;
      wishlistCountEl.style.display = count > 0 ? 'inline' : 'none';
    }
  }

  // ============= FUNGSI LOAD PRODUCT DROPDOWN =============
  async function loadProductDropdown() {
    const { data: products } = await supabase
      .from('products')
      .select('slug, name')
      .eq('is_active', true)
      .limit(10);

    const dropdown = document.querySelector('#productDropdown');
    const loadingEl = document.getElementById('loadingProducts');
    
    if (dropdown && products && loadingEl) {
      loadingEl.remove();
      
      products.forEach(product => {
        const li = document.createElement('li');
        li.innerHTML = `<a href="/product-details?slug=${product.slug}">${product.name}</a>`;
        dropdown.appendChild(li);
      });
    }
  }

  // ============= FUNGSI LOAD CART ITEMS UNTUK DROPDOWN =============
  async function loadCartItems() {
    const cartItemsList = document.getElementById('cartItemsList');
    const cartSubtotal = document.getElementById('cartSubtotal');
    const cartItemCount = document.getElementById('cartItemCount');
    const cartCountBadge = document.getElementById('cartCountBadge');

    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      if (cartItemsList) cartItemsList.innerHTML = '<div class="text-center text-muted py-3">Keranjang kosong</div>';
      if (cartItemCount) cartItemCount.textContent = '0 items';
      if (cartCountBadge) cartCountBadge.style.display = 'none';
      return;
    }

    const { data: cartItems, error } = await supabase
      .from('cart')
      .select(`
        id,
        quantity,
        products (id, name, slug, price, discount, image_url)
      `)
      .eq('user_id', user.id)
      .limit(5);

    if (error || !cartItems || cartItems.length === 0) {
      if (cartItemsList) cartItemsList.innerHTML = '<div class="text-center text-muted py-3">Keranjang kosong</div>';
      if (cartItemCount) cartItemCount.textContent = '0 items';
      if (cartCountBadge) cartCountBadge.style.display = 'none';
      return;
    }

    let subtotal = 0;
    let itemsHtml = '';

    cartItems.forEach(item => {
      const price = item.products.price;
      const discount = item.products.discount || 0;
      const discountedPrice = price * (1 - discount / 100);
      const itemTotal = discountedPrice * item.quantity;
      subtotal += itemTotal;

      itemsHtml += `
        <div class="cart-item">
          <div class="cart-item-img">
            <img src="${item.products.image_url || '/assets/store/img/product/product-placeholder.webp'}" alt="${item.products.name}" class="img-fluid">
          </div>
          <div class="cart-item-info">
            <h6>${item.products.name}</h6>
            <div class="cart-item-meta">
              <span class="cart-item-price">Rp ${discountedPrice.toLocaleString('id-ID')}</span>
              <span class="cart-item-qty">Qty: ${item.quantity}</span>
            </div>
          </div>
          <button class="cart-item-remove remove-cart-item" data-cart-id="${item.id}" aria-label="Remove item">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
      `;
    });

    if (cartItemsList) cartItemsList.innerHTML = itemsHtml;
    if (cartItemCount) cartItemCount.textContent = cartItems.length + ' items';
    if (cartCountBadge) {
      cartCountBadge.textContent = String(cartItems.length);
      cartCountBadge.style.display = 'inline';
    }
    if (cartSubtotal) cartSubtotal.textContent = 'Rp ' + subtotal.toLocaleString('id-ID');

    document.querySelectorAll('.remove-cart-item').forEach(btn => {
      btn.addEventListener('click', async function() {
        const cartId = this.dataset.cartId;
        const { error } = await supabase
          .from('cart')
          .delete()
          .eq('id', cartId);
        
        if (!error) {
          loadCartItems();
          document.dispatchEvent(new Event('cartUpdated'));
        }
      });
    });
  }

  // ============= FUNGSI UPDATE CART COUNT =============
  async function updateCartCount() {
    const { data: { user } } = await supabase.auth.getUser();
    const cartCountBadge = document.getElementById('cartCountBadge');
    const cartItemCount = document.getElementById('cartItemCount');
    
    if (user) {
      const { count } = await supabase
        .from('cart')
        .select('*', { count: 'exact', head: true })
        .eq('user_id', user.id);
      
      const total = count || 0;
      
      if (cartCountBadge) {
        if (total > 0) {
          cartCountBadge.textContent = String(total);
          cartCountBadge.style.display = 'inline';
        } else {
          cartCountBadge.style.display = 'none';
        }
      }
      
      if (cartItemCount) {
        cartItemCount.textContent = total + ' items';
      }
    } else {
      if (cartCountBadge) cartCountBadge.style.display = 'none';
      if (cartItemCount) cartItemCount.textContent = '0 items';
    }
  }

  // ============= LOGOUT HANDLER =============
  document.getElementById('logoutBtnHeader')?.addEventListener('click', async () => {
    try {
      await supabase.auth.signOut();
      window.location.href = '/';
    } catch (error) {
      console.error('Logout error:', error);
    }
  });

  // ============= JALANKAN =============
  checkAuthStatus();
  loadProductDropdown();
  loadCartItems();
  updateCartCount();

  // ============= DENGARKAN EVENT =============
  document.addEventListener('cartUpdated', function() {
    loadCartItems();
    updateCartCount();
  });

  document.addEventListener('wishlistUpdated', function() {
    loadWishlistCount();
  });

  // ============= RE-CEK AUTH KALAU STATUS BERUBAH (login/logout) =============
  supabase.auth.onAuthStateChange(() => {
    checkAuthStatus();
    loadCartItems();
    updateCartCount();
    loadWishlistCount();
  });
</script>