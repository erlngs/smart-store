---
const currentPath = Astro.url.pathname;
import { supabase } from "@/lib/supabase";

// Cek session di server
const { data: { session } } = await supabase.auth.getSession();
const user = session?.user || null;

let profile = null;
if (user) {
  const { data } = await supabase
    .from('profiles')
    .select('full_name')
    .eq('id', user.id)
    .single();
  profile = data;
}
---

<header id="header" class="header position-relative">
    <!-- Header Bar -->
    <div class="header-bar">
      <div class="container-fluid container-xl">
        <div class="d-flex align-items-center justify-content-between">

          <!-- Logo -->
          <a href="/" class="logo d-flex align-items-center">
            <h1 class="sitename">SmartStore</h1>
          </a>

          <!-- Search -->
          <form class="header-search d-none d-lg-flex">
            <input type="text" class="search-input" placeholder="Search products, categories, brands...">
            <button class="search-btn" type="submit">
              <i class="bi bi-search"></i>
              <span class="d-none d-xl-inline">Search</span>
            </button>
          </form>

          <!-- Quick Links -->
          <div class="quick-links d-none d-xl-flex align-items-center">
            <a href="#" class="quick-link">
              <i class="bi bi-geo-alt"></i>
              <span>Stores</span>
            </a>
            <a href="#" class="quick-link">
              <i class="bi bi-question-circle"></i>
              <span>Help</span>
            </a>
          </div>

          <!-- Header Actions -->
          <div class="header-actions d-flex align-items-center">

            <!-- Mobile Search Toggle -->
            <button class="action-icon mobile-search-toggle d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#mobileSearch" aria-expanded="false" aria-controls="mobileSearch">
              <i class="bi bi-search"></i>
            </button>

            <!-- Account -->
            <div class="dropdown account-dropdown">
              <button class="action-icon" data-bs-toggle="dropdown" aria-label="Account">
                <i class="bi bi-person"></i>
                <span class="action-label d-none d-md-inline">Account</span>
              </button>
              <div class="dropdown-menu account-panel">
                {user ? (
                  <>
                    <div class="account-panel-header">
                      <h6>Welcome, {profile?.full_name || 'User'}!</h6>
                      <p>{user.email}</p>
                    </div>
                    <div class="account-panel-links">
                      <a href="/account">
                        <i class="bi bi-person"></i>
                        <span>My Account</span>
                      </a>
                      <a href="/account#orders">
                        <i class="bi bi-box-seam"></i>
                        <span>My Orders</span>
                      </a>
                      <a href="#">
                        <i class="bi bi-heart"></i>
                        <span>Wishlist</span>
                      </a>
                    </div>
                    <div class="account-panel-auth">
                      <button id="logoutBtnHeader" class="btn btn-danger w-100">Logout</button>
                    </div>
                  </>
                ) : (
                  <>
                    <div class="account-panel-header">
                      <h6>Welcome!</h6>
                      <p>Sign in for the best experience</p>
                    </div>
                    <div class="account-panel-auth">
                      <a href="/login" class="btn btn-signin">Sign In</a>
                      <a href="/register" class="btn btn-register">Create Account</a>
                    </div>
                    <div class="account-panel-links">
                      <a href="#">
                        <i class="bi bi-box-seam"></i>
                        <span>My Orders</span>
                      </a>
                      <a href="#">
                        <i class="bi bi-arrow-return-left"></i>
                        <span>Returns &amp; Refunds</span>
                      </a>
                      <a href="#">
                        <i class="bi bi-question-circle"></i>
                        <span>Help Center</span>
                      </a>
                    </div>
                  </>
                )}
              </div>
            </div>

            <!-- Cart -->
            <div class="dropdown cart-dropdown">
              <button class="action-icon" data-bs-toggle="dropdown" aria-label="Cart">
                <i class="bi bi-cart3"></i>
                <span class="action-label d-none d-md-inline">Cart</span>
                <span class="count-dot" id="cartCount">0</span>
              </button>
              <div class="dropdown-menu cart-panel" id="cartPanel">
                <div class="cart-panel-header">
                  <h6>Shopping Cart</h6>
                  <span class="item-count" id="cartItemCount">0 items</span>
                </div>
                <div class="cart-panel-body" id="cartItems">
                  <div class="text-center text-muted py-3">Keranjang kosong</div>
                </div>
                <div class="cart-panel-footer">
                  <div class="cart-subtotal">
                    <span>Subtotal</span>
                    <span class="cart-subtotal-price" id="cartSubtotal">Rp 0</span>
                  </div>
                  <a href="/checkout" class="btn btn-checkout">Checkout</a>
                  <a href="/cart" class="btn-viewcart">View full cart →</a>
                </div>
              </div>
            </div>

            <!-- Mobile Navigation Toggle -->
            <i class="mobile-nav-toggle d-xl-none bi bi-list me-0"></i>

          </div>
        </div>
      </div>
    </div>

    <!-- Navigation -->
    <div class="header-nav">
      <div class="container-fluid container-xl position-relative">
        <nav id="navmenu" class="navmenu">
          <ul>
            <li><a href="/" class:list={{ active: currentPath === "/" }}>Home</a></li>
            <li><a href="/about" class:list={{ active: currentPath === "/about" }}>About</a></li>
            <li><a href="/category" class:list={{ active: currentPath === "/category" }}>Category</a></li>
            
            <!-- Products Dropdown -->
            <li class="dropdown">
              <a href="#"><span>Products</span> <i class="bi bi-chevron-down toggle-dropdown"></i></a>
              <ul id="productDropdown">
                <li><a href="/category">All Products</a></li>
                <li><hr class="dropdown-divider"></li>
                <li class="text-muted small px-3 py-1" id="loadingProducts">Loading products...</li>
              </ul>
            </li>

            <li><a href="/cart" class:list={{ active: currentPath === "/cart" }}>Cart</a></li>
            <li><a href="/checkout" class:list={{ active: currentPath === "/checkout" }}>Checkout</a></li>
            <li><a href="/contact" class:list={{ active: currentPath === "/contact" }}>Contact</a></li>
          </ul>
        </nav>
      </div>
    </div>
                
    <!-- Mobile Search Form -->
    <div class="collapse" id="mobileSearch">
      <div class="container-fluid container-xl">
        <form class="mobile-search-form">
          <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="form-control" placeholder="Search products...">
          </div>
        </form>
      </div>
    </div>

  </header>

<script>
  import { supabase } from "@/lib/supabase";

  // Load products untuk dropdown
  async function loadProductDropdown() {
    const { data: products } = await supabase
      .from('products')
      .select('slug, name')
      .eq('is_active', true)
      .limit(10);

    const dropdown = document.querySelector('#productDropdown');
    const loadingEl = document.getElementById('loadingProducts');
    
    if (dropdown && products && loadingEl) {
      loadingEl.remove();
      
      products.forEach(product => {
        const li = document.createElement('li');
        li.innerHTML = `<a href="/product-details?slug=${product.slug}">${product.name}</a>`;
        dropdown.appendChild(li);
      });
    }
  }

  // Load cart count
  async function loadCartCount() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      const { count } = await supabase
        .from('cart')
        .select('*', { count: 'exact', head: true })
        .eq('user_id', session.user.id);
      
      const cartCount = document.getElementById('cartCount');
      if (cartCount && count > 0) {
        cartCount.textContent = count;
        cartCount.style.display = 'inline';
      }
    }
  }

  // Logout handler
  document.getElementById('logoutBtnHeader')?.addEventListener('click', async () => {
    try {
      await supabase.auth.signOut();
      window.location.href = '/';
    } catch (error) {
      console.error('Logout error:', error);
    }
  });

  loadProductDropdown();
  loadCartCount();
</script>