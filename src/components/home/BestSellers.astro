---
// src/components/home/BestSellers.astro
import { supabase } from "../../lib/supabase/client";

// Ambil 4 produk terbaru
const { data: products, error } = await supabase
  .from('products')
  .select('*')
  .eq('is_active', true)
  .order('created_at', { ascending: false })
  .limit(4);

// Ambil rating untuk setiap produk
let productsWithRating = [];
if (products && products.length > 0) {
  for (const product of products) {
    // Ambil rata-rata rating
    const { data: ratings } = await supabase
      .from('reviews')
      .select('rating')
      .eq('product_id', product.id);
    
    let avgRating = 0;
    let totalReviews = 0;
    if (ratings && ratings.length > 0) {
      totalReviews = ratings.length;
      const sum = ratings.reduce((acc, r) => acc + r.rating, 0);
      avgRating = sum / totalReviews;
    }
    
    productsWithRating.push({
      ...product,
      avgRating: avgRating,
      totalReviews: totalReviews
    });
  }
}

// Fungsi render stars untuk rating
function renderStars(rating: number) {
  const fullStars = Math.floor(rating);
  const hasHalfStar = rating % 1 >= 0.5;
  let html = '';
  for (let i = 0; i < fullStars; i++) {
    html += '<i class="bi bi-star-fill"></i>';
  }
  if (hasHalfStar) {
    html += '<i class="bi bi-star-half"></i>';
  }
  while (html.split('<i').length - 1 < 5) {
    html += '<i class="bi bi-star"></i>';
  }
  return html;
}
---

<section id="best-sellers" class="best-sellers section">

  <!-- Section Title -->
  <div class="container section-title" data-aos="fade-up">
    <h2>Best Sellers</h2>
    <p>Temukan berbagai produk berkualitas dengan harga terbaik di SmartStore</p>
  </div>

  <div class="container" data-aos="fade-up" data-aos-delay="100">
    <div class="row g-4">

      {productsWithRating && productsWithRating.length > 0 ? (
        productsWithRating.map((product, index) => (
          <div class="col-lg-6" data-aos="fade-up" data-aos-delay={100 + (index * 100)}>
            <div class="catalog-card">
              <div class="row g-0">
                <div class="col-sm-5">
                  <div class="card-img-wrapper">
                    {product.discount > 0 && (
                      <span class="tag sale">{product.discount}% Off</span>
                    )}
                    {product.discount === 0 && (
                      <span class="tag">Exclusive</span>
                    )}
                    <img 
                      src={product.image_url || '/assets/store/img/product/product-placeholder.webp'} 
                      alt={product.name} 
                      class="img-fluid" 
                      loading="lazy"
                    />
                    <div class="quick-actions">
                      <button class="qaction-btn"><i class="bi bi-heart"></i></button>
                      <a href={`/product-details?slug=${product.slug}`} class="qaction-btn"><i class="bi bi-eye"></i></a>
                      <button class="qaction-btn"><i class="bi bi-shuffle"></i></button>
                    </div>
                  </div>
                </div>
                <div class="col-sm-7">
                  <div class="card-details">
                    <span class="label">{product.category || 'General'}</span>
                    <h4 class="title">
                      <a href={`/product-details?slug=${product.slug}`}>{product.name}</a>
                    </h4>
                    <div class="review-info">
                      <div class="star-group" set:html={renderStars(product.avgRating)} />
                      <span class="reviews">({product.totalReviews})</span>
                    </div>
                    <div class="pricing">
                      {product.discount > 0 ? (
                        <>
                          <span class="was">Rp {product.price.toLocaleString('id-ID')}</span>
                          <span class="now">Rp {(product.price * (1 - product.discount / 100)).toLocaleString('id-ID')}</span>
                        </>
                      ) : (
                        <span>Rp {product.price.toLocaleString('id-ID')}</span>
                      )}
                    </div>
                    <div class="variant-dots">
                      <span class="dot active" style="background-color: #2563eb;"></span>
                      <span class="dot" style="background-color: #059669;"></span>
                      <span class="dot" style="background-color: #dc2626;"></span>
                    </div>
                    <a href={`/product-details?slug=${product.slug}`} class="shop-btn">
                      Lihat Produk <i class="bi bi-arrow-right"></i>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))
      ) : (
        <div class="col-12 text-center py-5">
          <p>Belum ada produk tersedia.</p>
        </div>
      )}

    </div>
  </div>

</section>